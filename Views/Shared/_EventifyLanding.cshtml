            <p>Experience the future of event booking with our cutting edge features</p>
        </header>

        <div class="ev-grid ev-grid-3">
            <article class="ev-feature-card ev-reveal" style="--ev-delay:0s;"><span class="ev-mini-icon blue"><i class="bi bi-lightning-charge-fill"></i></span><h4>Instant Booking</h4><p>Book your favorite events instantly with just a few clicks.</p></article>
            <article class="ev-feature-card ev-reveal" style="--ev-delay:.06s;"><span class="ev-mini-icon green"><i class="bi bi-shield-lock-fill"></i></span><h4>Secure Payments</h4><p>Your payments are protected with bank-level security.</p></article>
            <article class="ev-feature-card ev-reveal" style="--ev-delay:.12s;"><span class="ev-mini-icon purple"><i class="bi bi-ticket-perforated-fill"></i></span><h4>Digital Tickets</h4><p>Access your tickets anytime, anywhere on your mobile device.</p></article>
            <article class="ev-feature-card ev-reveal" style="--ev-delay:.18s;"><span class="ev-mini-icon orange"><i class="bi bi-bell-fill"></i></span><h4>Event Reminders</h4><p>Never miss an event with smart notifications and reminders.</p></article>
            <article class="ev-feature-card ev-reveal" style="--ev-delay:.24s;"><span class="ev-mini-icon pink"><i class="bi bi-heart-fill"></i></span><h4>Wishlist Events</h4><p>Save events you love and get notified when tickets are available.</p></article>
            <article class="ev-feature-card ev-reveal" style="--ev-delay:.30s;"><span class="ev-mini-icon cyan"><i class="bi bi-graph-up-arrow"></i></span><h4>Trending Events</h4><p>Discover what's popular and trending in your area.</p></article>
        </div>
    </div>
</section>

<section id="events" class="ev-section ev-soft-bg">
    <div class="container">
        <header class="ev-section-head">
            <h2>@(hasSearch ? "Search Results" : "Popular Events")</h2>
            <p>@(hasSearch ? "Events matching your selected filters" : "Don't miss out on the most exciting events happening near you")</p>
        </header>

        <div class="ev-grid ev-grid-3">
            @if (events.Count == 0)
            {
                <article class="ev-event-card ev-reveal">
                    <div class="ev-event-body">
                        <h4>No events found</h4>
                        <p>Try changing location, date, or category filters.</p>
                    </div>
                </article>
            }
            else
            {
                @foreach (var item in events)
                {
                    <article class="ev-event-card ev-reveal" style="--ev-delay:@($"{Math.Min(0.36, events.IndexOf(item) * 0.06):0.00}s")">
                        <img src="@item.ImageUrl" alt="@item.Title" />
                        <div class="ev-event-body">
                            <h4>@item.Title</h4>
                            <p>@item.StartDateTime.ToString("MMMM d, yyyy")</p>
                            <p class="ev-meta">@item.Location</p>
                            <div class="ev-event-row">
                                <span><i class="bi bi-star-fill"></i> @item.Rating.ToString("0.0")</span>
                                <b>Rs @item.Price.ToString("0")</b>
                            </div>
                        </div>
                        <button type="button" onclick="window.location.href='@Url.Action("EventDetails", "Attend", new { id = item.Id })'">Book Now</button>
                    </article>
                }
            }
        </div>

        <div class="ev-center mt-4">
            <a class="ev-view-all" href="javascript:void(0)">View All Events</a>
        </div>
    </div>
</section>

