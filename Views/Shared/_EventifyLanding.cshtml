@using Eventify.Models
@{
    var events = ViewBag.Events as List<EventItem> ?? new List<EventItem>();
    var categories = ViewBag.Categories as List<string> ?? new List<string>();
    var searchLocation = ViewBag.SearchLocation as string ?? string.Empty;
    var searchDate = ViewBag.SearchDate as string ?? string.Empty;
    var selectedCategory = ViewBag.SelectedCategory as string ?? string.Empty;
    var hasSearch = ViewBag.HasSearch is bool searchRequested && searchRequested;
    var heroSlides = events
        .Select(e => new { e.ImageUrl, e.Title })
        .Where(x => !string.IsNullOrWhiteSpace(x.ImageUrl))
        .DistinctBy(x => x.ImageUrl)
        .Take(4)
        .ToList();

    if (heroSlides.Count == 0)
    {
        heroSlides.Add(new { ImageUrl = Url.Content("~/images/img.png"), Title = "Featured Event" });
    }
}

<nav class="ev-nav">
    <div class="container ev-nav-inner">
        <a class="ev-brand" href="#home">
            <span class="ev-brand-star"><i class="bi bi-star-fill"></i></span>
            <span>Eventify</span>
        </a>

        <div class="ev-main-links">
            <a href="#home">Home</a>
            <a href="#events">Events</a>
            <a href="#categories">Categories</a>
            <a href="#about">About</a>
            <a href="@Url.Action("Contact", "Home")">Contact</a>
        </div>

        <div class="ev-nav-actions">
            <a class="ev-link-btn" href="/Auth/Login">Login</a>
            <a class="ev-link-btn" href="/Auth/Register">Register</a>
            <a class="ev-primary-btn ev-primary-btn-sm" href="@Url.Action("Register", "Auth")">Get Started</a>
        </div>
    </div>
</nav>

<section id="home" class="ev-hero">
    <div class="container ev-hero-grid">
        <div class="ev-hero-left">
            <h1>Discover Amazing<br />Events Near You</h1>
            <p>
                Join thousands of people experiencing unforgettable moments.<br />
                Find and book the perfect event for you.
            </p>

            <div class="ev-search-box">
                <form method="get" action="@Url.Action("Index", "Home")">
                    <div class="ev-search-top">
                        <div class="ev-input-wrap">
                            <i class="bi bi-geo-alt"></i>
                            <input type="text" name="location" placeholder="Location" value="@searchLocation" />
                        </div>
                        <div class="ev-input-wrap">
                            <i class="bi bi-calendar-event"></i>
                            <input type="date" name="date" value="@searchDate" />
                        </div>
                        <div class="ev-input-wrap">
                            <i class="bi bi-tags"></i>
                            <select name="category">
                                <option value="">All Categories</option>
                                @foreach (var category in categories)
                                {
                                    if (string.Equals(category, selectedCategory, StringComparison.OrdinalIgnoreCase))
                                    {
                                        <option value="@category" selected>@category</option>
                                    }
                                    else
                                    {
                                        <option value="@category">@category</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>
                    <button class="ev-primary-btn" type="submit">Search Events</button>
                </form>
            </div>

            <div class="ev-hero-cta">
                <a class="ev-btn-white" href="#events">Explore Events</a>
                <a class="ev-btn-outline" href="#about">Learn More</a>
            </div>
        </div>

        <div class="ev-hero-right ev-hero-slider" data-slider>
            <div class="ev-hero-slides">
                @for (var i = 0; i < heroSlides.Count; i++)
                {
                    var slide = heroSlides[i];
                    <img class="ev-hero-slide @(i == 0 ? "is-active" : "")"
                         src="@slide.ImageUrl"
                         alt="@slide.Title"
                         data-slide-index="@i"
                         onerror="if(this.dataset.fallback!=='1'){this.dataset.fallback='1';this.src='@Url.Content("~/images/img.png")';}" />
                }
            </div>
            @if (heroSlides.Count > 1)
            {
                <div class="ev-hero-dots">
                    @for (var i = 0; i < heroSlides.Count; i++)
                    {
                        <button type="button"
                                class="ev-hero-dot @(i == 0 ? "is-active" : "")"
                                aria-label="Show slide @(i + 1)"
                                data-dot-index="@i"></button>
                    }
                </div>
            }
        </div>

    </div>
</section>

<section class="ev-stats-section">
    <div class="container ev-grid ev-grid-4">
        <article class="ev-stat-card ev-reveal" style="--ev-delay:0s;"><div class="ev-stat-icon blue"><i class="bi bi-calendar-week"></i></div><h3 class="ev-counter" data-target="10000" data-suffix="+">0</h3><p>Events</p></article>
        <article class="ev-stat-card ev-reveal" style="--ev-delay:.08s;"><div class="ev-stat-icon violet"><i class="bi bi-people-fill"></i></div><h3 class="ev-counter" data-target="50000" data-suffix="+">0</h3><p>Attendees</p></article>
        <article class="ev-stat-card ev-reveal" style="--ev-delay:.16s;"><div class="ev-stat-icon indigo"><i class="bi bi-file-earmark-text"></i></div><h3 class="ev-counter" data-target="2000" data-suffix="+">0</h3><p>Organizers</p></article>
        <article class="ev-stat-card ev-reveal" style="--ev-delay:.24s;"><div class="ev-stat-icon gold"><i class="bi bi-star-fill"></i></div><h3 class="ev-counter" data-target="4.9" data-decimals="1">0</h3><p>Rating</p></article>
    </div>
</section>

<section id="about" class="ev-section">
    <div class="container">
        <header class="ev-section-head">
