    <div class="container">
        <div class="ev-footer-grid">
            <div>
                <h4><i class="bi bi-star-fill"></i> Eventify</h4>
                <p>Discover amazing events happening around you. From concerts to conferences, we've got you covered.</p>
                <div class="ev-socials">
                    <a href="javascript:void(0)" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
                    <a href="javascript:void(0)" aria-label="Twitter"><i class="bi bi-twitter-x"></i></a>
                    <a href="javascript:void(0)" aria-label="LinkedIn"><i class="bi bi-linkedin"></i></a>
                    <a href="javascript:void(0)" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
                </div>
            </div>
            <div>
                <h5>Quick Links</h5>
                <a href="@Url.Action("AboutUs", "Home")">About Us</a><a href="@Url.Action("PartnerEvents", "Home")">Partner Events</a><a href="@Url.Action("FAQ", "Home")">FAQ</a><a href="@Url.Action("Pricing", "Home")">Pricing</a><a href="@Url.Action("Contact", "Home")">Contact</a>
            </div>
            <div>
                <h5>Categories</h5>
                <a href="javascript:void(0)">Music Events</a><a href="javascript:void(0)">Sports Events</a><a href="javascript:void(0)">Arts &amp; Culture</a><a href="javascript:void(0)">Food &amp; Drink</a><a href="javascript:void(0)">Business</a><a href="javascript:void(0)">Nightlife</a>
            </div>
            <div>
                <h5>Contact Info</h5>
                <p><i class="bi bi-geo-alt"></i> Patel Colony 3/5<br />Jamnagar, Gujarat, India</p>
                <p><i class="bi bi-telephone"></i> +91 81062 53134</p>
                <p><i class="bi bi-envelope"></i> mashrumihir13@gmail.com</p>
            </div>
        </div>
        <div class="ev-footer-bottom">
            <span>© 2026 Eventify. All rights reserved.</span>
            <div><a href="@Url.Action("PrivacyPolicy", "Home")">Privacy Policy</a><a href="@Url.Action("TermsOfService", "Home")">Terms of Service</a></div>
        </div>
