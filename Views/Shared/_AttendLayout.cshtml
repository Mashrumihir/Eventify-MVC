@{
    var activeNav = (ViewData["AttendNav"] as string ?? "").ToLowerInvariant();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Eventify</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        * { box-sizing: border-box; }
        body { margin: 0; font-family: "Segoe UI", Tahoma, sans-serif; background: #eef0f4; color: #1f2937; }
        .at-shell { min-height: 100vh; display: grid; grid-template-columns: 220px 1fr; }
        .at-sidebar { background: #f7f8fa; border-right: 1px solid #e4e7ec; padding: 16px 14px; }
        .at-brand { display: flex; align-items: center; gap: 10px; font-size: 33px; font-weight: 700; color: #1f2937; margin-bottom: 16px; text-decoration: none; }
        .at-brand i { color: #2f6bf4; font-size: 18px; }
        .at-nav { display: flex; flex-direction: column; gap: 6px; margin-top: 8px; }
        .at-nav a { display: flex; align-items: center; gap: 11px; padding: 11px 12px; border-radius: 10px; color: #374151; text-decoration: none; font-size: 16px; font-weight: 500; }
        .at-nav a.active { color: #fff; background: #3b82f6; }
        .at-nav a.logout { color: #ef4444; margin-top: 8px; }
        .at-main { min-width: 0; }
        .at-topbar { height: 58px; border-bottom: 1px solid #e5e7eb; background: #f7f8fa; display: flex; align-items: center; justify-content: flex-end; padding: 0 18px; }
        .at-user { display: inline-flex; align-items: center; gap: 8px; font-size: 14px; }
        .at-avatar { width: 24px; height: 24px; border-radius: 50%; border: 1px solid #111827; display: inline-flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 700; }
        @@media (max-width: 860px) {
            .at-shell { grid-template-columns: 1fr; }
            .at-sidebar { border-right: 0; border-bottom: 1px solid #e4e7ec; }
            .at-nav a { font-size: 14px; }
        }
    </style>
    @await RenderSectionAsync("PageStyles", required: false)
</head>
<body>
    <div class="at-shell">
        <aside class="at-sidebar">
            <a class="at-brand" href="#"><i class="bi bi-star-fill"></i><span>Eventify</span></a>
            <nav class="at-nav">
                <a class="@(activeNav == "dashboard" ? "active" : "")" href="/Attend/Dashboard"><i class="bi bi-house-fill"></i>Dashboard</a>
                <a class="@(activeNav == "browse" ? "active" : "")" href="/Attend/BrowseEvents"><i class="bi bi-calendar-event"></i>Browse Events</a>
                <a class="@(activeNav == "bookings" ? "active" : "")" href="/Attend/MyBookings"><i class="bi bi-ticket-perforated"></i>My Bookings</a>
                <a class="@(activeNav == "wishlist" ? "active" : "")" href="/Attend/Wishlist"><i class="bi bi-heart-fill"></i>Wishlist</a>
                <a class="@(activeNav == "notifications" ? "active" : "")" href="/Attend/Notifications"><i class="bi bi-bell-fill"></i>Notifications</a>
                <a class="@(activeNav == "reviews" ? "active" : "")" href="/Attend/Reviews"><i class="bi bi-star-fill"></i>Reviews</a>
                <a class="@(activeNav == "profile" ? "active" : "")" href="/Attend/ProfileSettings"><i class="bi bi-person-gear"></i>Profile Settings</a>
                <a class="logout" href="/Auth/Logout"><i class="bi bi-box-arrow-right"></i>Logout</a>
            </nav>
        </aside>

        <main class="at-main">
            <header class="at-topbar">
                <div class="at-user"><span class="at-avatar">MM</span><span>Mihir Mashru <i class="bi bi-chevron-down"></i></span></div>
            </header>
            @RenderBody()
        </main>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
