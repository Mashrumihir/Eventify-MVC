<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Eventify</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        * { box-sizing: border-box; }
        body { margin: 0; font-family: "Segoe UI", Tahoma, sans-serif; background: #d7dee8; color: #1f2937; }
        .ad-shell { min-height: 100vh; display: grid; grid-template-columns: 280px minmax(0,1fr); }
        .ad-side {
            background: linear-gradient(180deg, #2f4b8f, #355b9f);
            color: #e2ebff;
            display: flex;
            flex-direction: column;
            border-right: 1px solid rgba(255,255,255,.18);
            position: sticky;
            top: 0;
            height: 100vh;
            overflow-y: auto;
        }
        .ad-brand { padding: 24px 22px; border-bottom: 1px solid rgba(255,255,255,.12); }
        .ad-brand h2 { margin: 0; font-size: 36px; line-height: 1; font-weight: 800; color: #fff; }
        .ad-brand p { margin: 8px 0 0; font-size: 28px; color: #c5d3f7; }
        .ad-nav { display: flex; flex-direction: column; gap: 10px; padding: 18px 16px; flex: 1; }
        .ad-nav a { display: flex; align-items: center; gap: 14px; color: #eff5ff; text-decoration: none; padding: 12px 14px; border-radius: 12px; font-size: 28px; }
        .ad-nav a.active { background: rgba(255,255,255,.16); }
        .ad-nav a.logout { margin-top: auto !important; color: #ff6b6b !important; }
        .ad-main { min-width: 0; min-height: 100vh; }
        .ad-top { background: #fff; border-bottom: 1px solid #d7dfed; padding: 24px 32px; }
        .ad-top h3 { margin: 0; font-size: 44px; color: #1f365f; }
        .ad-top p { margin: 6px 0 0; font-size: 34px; color: #6b7280; }
        .ad-content { padding: 26px 30px; }

        .pill-group { display: inline-flex; gap: 10px; border-radius: 999px; background: #e7ecf4; padding: 6px; }
        .pill { color: #4b5563; text-decoration: none; border-radius: 999px; padding: 10px 18px; font-size: 16px; }
        .pill.active { background: #cfd7e5; color: #1f3e76; font-weight: 700; }

        .btn-grad { border: 0; border-radius: 14px; color: #fff; background: linear-gradient(90deg,#334e9a,#27a7cb); padding: 10px 20px; font-size: 16px; cursor: pointer; }
        .btn-outline-red { border: 2px solid #ef4444; color: #ef4444; background: #fff; border-radius: 999px; padding: 8px 18px; font-weight: 600; }
        .card { background: #fff; border: 1px solid #c7d8f2; border-radius: 18px; }

        @@media (max-width: 1200px) {
            .ad-shell { grid-template-columns: 220px minmax(0,1fr); }
            .ad-brand h2 { font-size: 30px; }
            .ad-brand p { font-size: 22px; }
            .ad-nav a { font-size: 20px; }
            .ad-top h3 { font-size: 34px; }
            .ad-top p { font-size: 24px; }
        }

        @@media (max-width: 900px) {
            .ad-shell { grid-template-columns: 1fr; }
            .ad-side {
                position: static;
                height: auto;
                overflow: visible;
            }
            .ad-nav a { font-size: 16px; }
            .ad-top h3 { font-size: 28px; }
            .ad-top p { font-size: 18px; }
        }
    </style>
    @await RenderSectionAsync("PageStyles", required: false)
    <style>
        /* Compact admin layout sizing */
        .ad-shell { grid-template-columns: 220px minmax(0,1fr) !important; }
        .ad-brand { padding: 12px !important; }
        .ad-brand h2 { font-size: 14px !important; }
        .ad-brand p { font-size: 11px !important; margin-top: 4px !important; }

        .ad-nav { padding: 8px !important; gap: 6px !important; flex: 1 !important; }
        .ad-nav a { font-size: 13px !important; padding: 8px 10px !important; gap: 8px !important; border-radius: 10px !important; }

        .ad-top { padding: 10px 14px !important; }
        .ad-top h3 { font-size: 15px !important; }
        .ad-top p { font-size: 12px !important; margin-top: 4px !important; }
        .ad-content { padding: 12px 14px !important; }

        .ad-content .ad-title { font-size: 18px !important; margin: 0 0 4px !important; }
        .ad-content .ad-sub { font-size: 13px !important; margin: 0 0 10px !important; }

        .ad-content h1 { font-size: 20px !important; line-height: 1.2 !important; }
        .ad-content h2 { font-size: 16px !important; line-height: 1.25 !important; }
        .ad-content h3 { font-size: 14px !important; line-height: 1.3 !important; }
        .ad-content p,
        .ad-content a,
        .ad-content li,
        .ad-content td,
        .ad-content th,
        .ad-content label,
        .ad-content input,
        .ad-content select,
        .ad-content textarea,
        .ad-content button { font-size: 12px !important; line-height: 1.35 !important; }

        .ad-content .card { border-radius: 12px !important; }
        .ad-content .card,
        .ad-content .stat,
        .ad-content .app,
        .ad-content .fin,
        .ad-content .page,
        .ad-content .list,
        .ad-content .pending { padding: 10px !important; }

        .ad-content .stat .n { font-size: 22px !important; }
        .ad-content .stat .l { font-size: 13px !important; }
        .ad-content .row .name { font-size: 14px !important; }
        .ad-content .row .meta { font-size: 12px !important; }
        .ad-content .search input { font-size: 13px !important; padding: 8px 12px !important; }
        .ad-content .btn,
        .ad-content .btn-grad,
        .ad-content .btn-outline-red { font-size: 12px !important; padding: 7px 12px !important; }

        @@media (max-width: 900px) {
            .ad-shell { grid-template-columns: 1fr !important; }
            .ad-side {
                position: static !important;
                height: auto !important;
                overflow: visible !important;
            }
            .ad-brand h2 { font-size: 13px !important; }
            .ad-brand p { font-size: 10px !important; }
            .ad-nav a { font-size: 12px !important; }
            .ad-content .ad-title { font-size: 16px !important; }
            .ad-content .ad-sub { font-size: 12px !important; }
            .ad-content h1 { font-size: 18px !important; }
            .ad-content h2 { font-size: 15px !important; }
            .ad-content h3 { font-size: 13px !important; }
        }
    </style>
</head>
<body>
    @{
        var nav = (ViewData["AdminNav"]?.ToString() ?? string.Empty).ToLowerInvariant();
        string Active(string key) => nav == key ? "active" : string.Empty;
    }

    <div class="ad-shell">
        <aside class="ad-side">
            <div class="ad-brand">
                <h2>Admin Panel</h2>
                <p>Control Center</p>
            </div>
            <nav class="ad-nav">
                <a class="@Active("dashboard")" href="@Url.Action("Dashboard", "Admin")"><i class="bi bi-graph-up"></i> Dashboard</a>
                <a class="@Active("users")" href="@Url.Action("UserManagement", "Admin")"><i class="bi bi-people-fill"></i> User Management</a>
                <a class="@Active("approvals")" href="@Url.Action("OrganizerApproval", "Admin")"><i class="bi bi-person-check-fill"></i> Organizer Approval</a>
                <a class="@Active("settings")" href="@Url.Action("SystemSettings", "Admin")"><i class="bi bi-gear-fill"></i> System Settings</a>
                <a class="@Active("notifications")" href="@Url.Action("Notifications", "Admin")"><i class="bi bi-bell-fill"></i> Notifications</a>
                <a class="@Active("newsletter")" href="@Url.Action("NewsletterSubscribers", "Admin")"><i class="bi bi-envelope-fill"></i> Newsletter Subscribers</a>
                <a class="@Active("reviews")" href="@Url.Action("ReviewsRatings", "Admin")"><i class="bi bi-star-half"></i> Reviews & Ratings</a>
                <a class="logout" href="/Auth/Logout"><i class="bi bi-box-arrow-right"></i> Logout</a>
            </nav>
        </aside>

        <main class="ad-main">
            <section class="ad-top">
                <h3>Welcome back, Admin</h3>
                <p>Manage your platform effectively</p>
            </section>
            <section class="ad-content">
                @RenderBody()
            </section>
        </main>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
