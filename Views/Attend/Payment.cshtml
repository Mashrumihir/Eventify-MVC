@model Eventify.ViewModels.PaymentViewModel
@{
    Layout = "_AttendLayout";
    ViewData["Title"] = "Payment";
}

@section PageStyles {
    <style>
        .pay-wrap { padding: 16px; display: grid; grid-template-columns: 1fr 320px; gap: 12px; align-items: start; }
        .pay-main h1 { margin: 0; font-size: 52px; font-weight: 800; color: #0f2547; }
        .pay-sub { margin: 2px 0 12px; color: #5e7698; font-size: 18px; }
        .pay-back { color: #1f4e8a; text-decoration: none; font-size: 14px; }
        .pay-card { background: #fff; border: 1px solid #d7dfeb; border-radius: 14px; padding: 10px; }
        .pay-title { margin: 0 0 8px; font-size: 42px; font-weight: 800; color: #0e2a52; }

        .pay-method-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
        .pay-method { border: 1px solid #cbd5e1; border-radius: 10px; padding: 8px; background: #f9fbff; cursor: pointer; text-align: left; }
        .pay-method.active { border-color: #3b82f6; box-shadow: inset 0 0 0 1px #3b82f6; background: #f3f8ff; }
        .pay-method b { display: block; font-size: 16px; color: #0f2547; }
        .pay-method span { font-size: 12px; color: #5d7393; }

        .pay-panel { display: none; }
        .pay-panel.active { display: block; }

        .pay-field { margin: 8px 0; }
        .pay-field label { display: block; font-size: 14px; color: #0f2547; margin-bottom: 4px; }
        .pay-field input,
        .pay-field select { width: 100%; border: 1px solid #c0cde1; border-radius: 10px; height: 38px; padding: 0 10px; font-size: 14px; }
        .pay-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }

        .wallet-row { display: flex; gap: 8px; flex-wrap: wrap; }
        .wallet-pill { border: 1px solid #d5deea; border-radius: 8px; padding: 6px 12px; font-size: 13px; cursor: pointer; background: #f5f8ff; color: #0f2547; }
        .wallet-pill.active { background: #2563eb; border-color: #2563eb; color: #fff; }

        .pay-note { margin-top: 8px; border: 1px solid #b3cdf8; border-radius: 10px; padding: 8px; color: #1f4ecf; background: #eff6ff; font-size: 12px; }

        .pay-side h2 { margin: 0 0 8px; font-size: 22px; color: #0f2547; }
        .pay-side h3 { margin: 0 0 6px; font-size: 40px; color: #0f2547; }
        .pay-side p { margin: 4px 0; color: #546b89; }
        .sum-row { display: flex; justify-content: space-between; margin: 6px 0; color: #173057; font-size: 16px; }
        .sum-total { font-size: 40px; font-weight: 800; color: #1f4fff; border-top: 1px solid #dbe4f1; margin-top: 8px; padding-top: 8px; }
        .pay-btn { width: 100%; height: 44px; border: 0; border-radius: 10px; color: #fff; font-size: 20px; font-weight: 800; background: linear-gradient(90deg, #3b82f6, #06b6d4); cursor: pointer; }
        .pay-disclaimer { margin-top: 8px; color: #5f7391; font-size: 12px; text-align: center; }

        @@media (max-width: 1080px) { .pay-wrap { grid-template-columns: 1fr; } }
        @@media (max-width: 680px) { .pay-method-grid, .pay-grid-2 { grid-template-columns: 1fr; } .pay-main h1 { font-size: 34px; } .pay-title, .pay-side h3, .sum-total { font-size: 28px; } }
    </style>
}

<section class="pay-wrap">
    <div class="pay-main">
        <a class="pay-back" href="/Attend/EventDetails/@Model.Event.Id">← Back to Event Details</a>
        <h1>Complete Your Payment</h1>
        <p class="pay-sub">Secure payment powered by Eventify</p>

        <article class="pay-card">
            <h2 class="pay-title">Select Payment Method</h2>
            <div class="pay-method-grid">
                <button class="pay-method active" data-method="card" type="button"><b>Credit / Debit Card</b><span>Visa, Mastercard, Amex</span></button>
                <button class="pay-method" data-method="upi" type="button"><b>UPI</b><span>GPay, PhonePe, Paytm</span></button>
                <button class="pay-method" data-method="bank" type="button"><b>Net Banking</b><span>All major banks</span></button>
                <button class="pay-method" data-method="wallet" type="button"><b>Wallet</b><span>Paytm, Amazon Pay</span></button>
            </div>
        </article>

        <article id="panel-card" class="pay-card pay-panel active" style="margin-top:8px;">
            <h2 class="pay-title">Card Details</h2>
            <div class="pay-field">
                <label>Card Number</label>
                <input type="text" placeholder="1234 5678 9012 3456" />
            </div>
            <div class="pay-field">
                <label>Cardholder Name</label>
                <input type="text" placeholder="Abc" />
            </div>
            <div class="pay-grid-2">
                <div class="pay-field">
                    <label>Expiry Date</label>
                    <input type="text" placeholder="MM/YY" />
                </div>
                <div class="pay-field">
                    <label>CVV</label>
                    <input type="text" placeholder="123" />
                </div>
            </div>
        </article>

        <article id="panel-upi" class="pay-card pay-panel" style="margin-top:8px;">
            <h2 class="pay-title">Enter UPI ID</h2>
            <div class="pay-field">
                <input type="text" placeholder="yourname@upi" />
            </div>
        </article>

        <article id="panel-bank" class="pay-card pay-panel" style="margin-top:8px;">
            <h2 class="pay-title">Select Your Bank</h2>
            <div class="pay-field">
                <select>
                    <option>Select a bank</option>
                    <option>HDFC Bank</option>
                    <option>ICICI Bank</option>
                    <option>SBI</option>
                    <option>Axis Bank</option>
                </select>
            </div>
        </article>

        <article id="panel-wallet" class="pay-card pay-panel" style="margin-top:8px;">
            <h2 class="pay-title">Select Wallet</h2>
            <div class="wallet-row">
                <button type="button" class="wallet-pill active">Paytm</button>
                <button type="button" class="wallet-pill">Amazon Pay</button>
                <button type="button" class="wallet-pill">PhonePe</button>
            </div>
        </article>

        <div class="pay-note">
            <i class="bi bi-lock-fill"></i> Your payment information is encrypted and secure. We do not store your card details.
        </div>
    </div>

    <aside class="pay-card pay-side">
        <h2>Order Summary</h2>
        <h3>@Model.Event.Title</h3>
        <p><i class="bi bi-calendar3"></i> @Model.Event.StartDateTime.ToString("MMMM d, yyyy")</p>
        <p><i class="bi bi-geo-alt"></i> @Model.Event.Location</p>
        <p><i class="bi bi-ticket-perforated"></i> @Model.TicketName</p>
        <p><i class="bi bi-people"></i> Quantity: @Model.Quantity</p>

        <div style="margin-top:14px;">
            <div class="sum-row"><span>@Model.TicketName × @Model.Quantity</span><strong>&#8377;@((Model.TicketPrice * Model.Quantity).ToString("0.00"))</strong></div>
            <div class="sum-row"><span>Discount (0%)</span><strong style="color:#059669;">-&#8377;@Model.Discount.ToString("0.00")</strong></div>
            <div class="sum-row sum-total"><span>Total</span><strong>&#8377;@Model.Total.ToString("0.00")</strong></div>
        </div>

        <form method="get" action="@Url.Action("PaymentSuccess", "Attend")">
            <input type="hidden" name="id" value="@Model.Event.Id" />
            <input type="hidden" name="ticket" value="@Model.TicketName" />
            <input type="hidden" name="total" value="@Model.Total" />
            <input type="hidden" name="qty" value="@Model.Quantity" />
            <input type="hidden" id="selectedMethodInput" name="method" value="Card" />
            <button class="pay-btn" type="submit">
                @(Model.Total <= 0 ? "Confirm Free Booking" : $"Pay ₹{Model.Total:0.00}")
            </button>
        </form>
        <p class="pay-disclaimer">By completing this purchase you agree to our Terms of Service.</p>
    </aside>
</section>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const methods = Array.from(document.querySelectorAll(".pay-method"));
            const selectedMethodInput = document.getElementById("selectedMethodInput");
            const panels = {
                card: document.getElementById("panel-card"),
                upi: document.getElementById("panel-upi"),
                bank: document.getElementById("panel-bank"),
                wallet: document.getElementById("panel-wallet")
            };
            const methodNames = {
                card: "Card",
                upi: "UPI",
                bank: "Net Banking",
                wallet: "Wallet"
            };

            methods.forEach(function (btn) {
                btn.addEventListener("click", function () {
                    methods.forEach(function (m) { m.classList.remove("active"); });
                    btn.classList.add("active");

                    Object.values(panels).forEach(function (p) { p.classList.remove("active"); });
                    const method = btn.getAttribute("data-method");
                    if (panels[method]) {
                        panels[method].classList.add("active");
                    }
                    if (selectedMethodInput && methodNames[method]) {
                        selectedMethodInput.value = methodNames[method];
                    }
                });
            });

            document.querySelectorAll(".wallet-pill").forEach(function (pill) {
                pill.addEventListener("click", function () {
                    document.querySelectorAll(".wallet-pill").forEach(function (p) { p.classList.remove("active"); });
                    pill.classList.add("active");
                    if (selectedMethodInput) {
                        selectedMethodInput.value = pill.textContent.trim();
                    }
                });
            });
        });
    </script>
}
