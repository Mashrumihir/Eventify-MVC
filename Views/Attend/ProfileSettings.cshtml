@model Eventify.ViewModels.AttendProfileSettingsViewModel
@{
    Layout = "_AttendLayout";
    ViewData["Title"] = "Profile Settings";
    var activeTab = string.Equals(Model.ActiveTab, "password", StringComparison.OrdinalIgnoreCase) ? "password" : "edit";
    var displayName = string.IsNullOrWhiteSpace(Model.FullName) ? "Attend User" : Model.FullName.Trim();
    var nameParts = displayName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
    var initials = nameParts.Length switch
    {
        0 => "AU",
        1 => nameParts[0].Length >= 2 ? nameParts[0][..2].ToUpperInvariant() : nameParts[0].ToUpperInvariant(),
        _ => $"{nameParts[0][0]}{nameParts[^1][0]}".ToUpperInvariant()
    };
}

@section PageStyles {
    <style>
        .ps-wrap { padding: 16px 18px; background: #d4dbe5; min-height: calc(100vh - 58px); }
        .ps-title { margin: 0; color: #1b2a42; font-size: 22px; font-weight: 800; line-height: 1.1; }
        .ps-sub { margin: 4px 0 10px; color: #607794; font-size: 12px; }

        .ps-grid { display: grid; grid-template-columns: 220px 1fr; gap: 12px; align-items: start; }
        .ps-menu, .ps-panel { background: #fff; border: 1px solid #dbe3ef; border-radius: 14px; padding: 12px; }

        .ps-nav { display: grid; gap: 8px; }
        .ps-nav a {
            text-decoration: none;
            color: #3d4d63;
            border-radius: 12px;
            padding: 10px 12px;
            font-size: 14px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .ps-nav a.active { background: linear-gradient(90deg, #3b82f6, #06b6d4); color: #fff; }

        .ps-msg { border-radius: 10px; padding: 8px 10px; margin-bottom: 10px; font-size: 14px; }
        .ps-msg.ok { background: #dcfce7; color: #166534; border: 1px solid #86efac; }
        .ps-msg.err { background: #fee2e2; color: #b91c1c; border: 1px solid #fca5a5; }

        .ps-head { margin: 0 0 10px; color: #1a2a43; font-size: 24px; font-weight: 800; }
        .ps-profile-top { display: flex; gap: 14px; align-items: center; padding-bottom: 12px; border-bottom: 1px solid #dbe3ef; margin-bottom: 12px; }
        .ps-avatar {
            width: 64px;
            height: 64px;
            border-radius: 999px;
            background: linear-gradient(135deg, #3b82f6, #06b6d4);
            color: #fff;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            font-weight: 800;
            position: relative;
        }
        .ps-camera-btn {
            position: absolute;
            right: -2px;
            bottom: -2px;
            width: 24px;
            height: 24px;
            border-radius: 999px;
            border: 1px solid #cbd5e1;
            background: #fff;
            color: #4b5563;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            cursor: pointer;
        }
        .ps-avatar img { width: 100%; height: 100%; border-radius: 999px; object-fit: cover; }
        .ps-upload-title { margin: 0; color: #1e2d46; font-size: 14px; font-weight: 800; }
        .ps-upload-sub { margin: 3px 0 4px; color: #5f7493; font-size: 12px; }
        .ps-upload-link { color: #2563eb; text-decoration: none; font-size: 12px; font-weight: 600; }
        .ps-upload-input { display: none; }

        .ps-form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px 12px; }
        .ps-field label { display: block; margin-bottom: 4px; color: #1f3552; font-size: 13px; }
        .ps-field input, .ps-field textarea {
            width: 100%;
            height: 42px;
            border: 1px solid #bccbe0;
            border-radius: 12px;
            padding: 0 12px;
            font-size: 15px;
            color: #152846;
            background: #fff;
        }
        .ps-field textarea { min-height: 96px; padding: 10px 12px; resize: vertical; }
        .ps-full { grid-column: 1 / -1; }
        .ps-actions { margin-top: 12px; display: flex; gap: 10px; }

        .ps-btn {
            height: 42px;
            border-radius: 12px;
            border: 1px solid #bccbe0;
            background: #fff;
            color: #1f3552;
            font-size: 15px;
            font-weight: 700;
            padding: 0 26px;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
        }
        .ps-btn.primary { border-color: transparent; color: #fff; background: linear-gradient(90deg, #3b82f6, #06b6d4); }

        .ps-note {
            margin-top: 12px;
            border: 1px solid #9ebef0;
            background: #edf4ff;
            border-radius: 12px;
            padding: 10px 12px 10px;
            color: #4b5f7c;
            box-shadow: 0 0 0 rgba(37, 99, 235, 0);
            transition: box-shadow .25s ease, transform .25s ease;
            animation: ps-note-float 4s ease-in-out infinite .4s;
        }
        .ps-note:hover {
            box-shadow: 0 8px 22px rgba(37, 99, 235, .14);
            transform: translateY(-2px);
        }
        .ps-note h4 {
            position: relative;
            margin: 0 0 10px;
            padding-bottom: 10px;
            font-size: 14px;
            font-weight: 800;
            color: #243b63;
            border-bottom: 4px solid #d7e8ff;
            animation: ps-divider-glow 2.6s ease-in-out infinite;
            overflow: hidden;
        }
        .ps-note h4::after {
            content: "";
            position: absolute;
            left: -35%;
            bottom: -4px;
            width: 35%;
            height: 4px;
            background: linear-gradient(90deg, transparent, #6ea8ff, transparent);
            animation: ps-divider-sweep 2s linear infinite;
        }
        .ps-note ul {
            margin: 0;
            padding-left: 18px;
            color: #284a7a;
            font-size: 14px;
            line-height: 1.55;
        }
        .ps-note li {
            margin: 2px 0;
            opacity: 0;
            transform: translateX(-8px);
            animation: ps-note-li-in .35s ease-out forwards;
        }
        .ps-note li:nth-child(1) { animation-delay: .10s; }
        .ps-note li:nth-child(2) { animation-delay: .18s; }
        .ps-note li:nth-child(3) { animation-delay: .26s; }
        .ps-note li:nth-child(4) { animation-delay: .34s; }
        .ps-note li::marker { color: #2563eb; }
        @@keyframes ps-note-li-in {
            from { opacity: 0; transform: translateX(-8px); }
            to { opacity: 1; transform: translateX(0); }
        }
        @@keyframes ps-note-float {
            0% { transform: translateY(0); }
            50% { transform: translateY(-2px); }
            100% { transform: translateY(0); }
        }
        @@keyframes ps-divider-glow {
            0% { border-bottom-color: #d7e8ff; }
            50% { border-bottom-color: #9cc2ff; }
            100% { border-bottom-color: #d7e8ff; }
        }
        @@keyframes ps-divider-sweep {
            0% { left: -35%; }
            100% { left: 100%; }
        }

        .nt-item { display: flex; align-items: center; justify-content: space-between; gap: 12px; padding: 12px 0; border-bottom: 1px solid #e5e7eb; }
        .nt-item:last-of-type { border-bottom: 0; }
        .nt-name { color: #1f2f48; font-size: 15px; font-weight: 700; margin: 0; }
        .nt-sub { color: #64748b; font-size: 13px; margin: 2px 0 0; }
        .sw { position: relative; width: 48px; height: 26px; }
        .sw input { display: none; }
        .sw span {
            position: absolute; inset: 0; background: #c7cdd6; border-radius: 999px; cursor: pointer; transition: .2s;
        }
        .sw span::before {
            content: ""; position: absolute; width: 20px; height: 20px; left: 3px; top: 3px; background: #fff; border-radius: 50%; transition: .2s;
        }
        .sw input:checked + span { background: linear-gradient(90deg, #3b82f6, #06b6d4); }
        .sw input:checked + span::before { transform: translateX(22px); }

        @@media (max-width: 1100px) { .ps-grid { grid-template-columns: 1fr; } .ps-form-grid { grid-template-columns: 1fr; } }
    </style>
}

<section class="ps-wrap">
    <h1 class="ps-title">Profile Settings</h1>
    <p class="ps-sub">Manage your account settings and preferences</p>

    <div class="ps-grid">
        <aside class="ps-menu">
            <nav class="ps-nav">
                <a class="@(activeTab == "edit" ? "active" : "")" href="/Attend/ProfileSettings?tab=edit"><i class="bi bi-person-fill"></i>Edit Profile</a>
                <a class="@(activeTab == "password" ? "active" : "")" href="/Attend/ProfileSettings?tab=password"><i class="bi bi-lock-fill"></i>Change Password</a>
            </nav>
        </aside>

        <section class="ps-panel">
            @if (!string.IsNullOrWhiteSpace(Model.Message))
            {
                <div class="ps-msg ok">@Model.Message</div>
            }
            @if (!string.IsNullOrWhiteSpace(Model.Error))
            {
                <div class="ps-msg err">@Model.Error</div>
            }

            @if (activeTab == "edit")
            {
                <h2 class="ps-head">Edit Profile</h2>
                <form method="post" action="@Url.Action("SaveProfile", "Attend")" enctype="multipart/form-data" id="profile-edit-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ActiveTab" value="edit" />
                    <input class="ps-upload-input" id="profile-photo-input" type="file" name="profilePhoto" accept=".jpg,.jpeg,.png,.webp" />

                <div class="ps-profile-top">
                    <div class="ps-avatar">
                        @if (!string.IsNullOrWhiteSpace(Model.ProfilePhotoPath))
                        {
                            <img src="@Model.ProfilePhotoPath" alt="Profile photo" />
                        }
                        else
                        {
                            @initials
                        }
                        <label class="ps-camera-btn" for="profile-photo-input" title="Upload Photo">
                            <i class="bi bi-camera-fill"></i>
                        </label>
                    </div>
                    <div>
                        <p class="ps-upload-title">Profile Photo</p>
                        <p class="ps-upload-sub">Upload a new photo or change existing</p>
                        <a class="ps-upload-link" href="#" id="profile-photo-link">Upload Photo</a>
                    </div>
                </div>
                    <div class="ps-form-grid">
                        <div class="ps-field">
                            <label>Full Name</label>
                            <input name="FullName" value="@Model.FullName" />
                        </div>
                        <div class="ps-field">
                            <label>Email Address</label>
                            <input name="Email" value="@Model.Email" readonly />
                        </div>
                        <div class="ps-field">
                            <label>Phone Number</label>
                            <input name="PhoneNumber" value="@Model.PhoneNumber" />
                        </div>
                        <div class="ps-field">
                            <label>Location</label>
                            <input name="Location" value="@Model.Location" />
                        </div>
                        <div class="ps-field">
                            <label>Date of Birth</label>
                            <input type="date" name="DateOfBirth" value="@(Model.DateOfBirth?.ToString("yyyy-MM-dd") ?? "")" />
                        </div>
                        <div class="ps-field ps-full">
                            <label>Bio</label>
                            <textarea name="Bio">@Model.Bio</textarea>
                        </div>
                    </div>
                    <div class="ps-actions">
                        <button class="ps-btn primary" type="submit">Save Changes</button>
                        <a class="ps-btn" href="/Attend/ProfileSettings?tab=edit">Cancel</a>
                    </div>
                </form>
            }
            else if (activeTab == "password")
            {
                <h2 class="ps-head">Change Password</h2>
                <form method="post" action="@Url.Action("ChangePassword", "Attend")">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ActiveTab" value="password" />
                    <div class="ps-form-grid">
                        <div class="ps-field ps-full">
                            <label>Current Password</label>
                            <input type="password" name="CurrentPassword" placeholder="Enter current password" />
                        </div>
                        <div class="ps-field ps-full">
                            <label>New Password</label>
                            <input type="password" name="NewPassword" placeholder="Enter new password" />
                        </div>
                        <div class="ps-field ps-full">
                            <label>Confirm New Password</label>
                            <input type="password" name="ConfirmPassword" placeholder="Confirm new password" />
                        </div>
                    </div>

                    <div class="ps-note">
                        <h4>Password must contain:</h4>
                        <ul>
                            <li>At least 8 characters long</li>
                            <li>Include uppercase and lowercase letters</li>
                            <li>Include at least one number</li>
                            <li>Include at least one special character</li>
                        </ul>
                    </div>

                    <div class="ps-actions">
                        <button class="ps-btn primary" type="submit">Update Password</button>
                        <a class="ps-btn" href="/Attend/ProfileSettings?tab=password">Cancel</a>
                    </div>
                </form>
            }
        </section>
    </div>
</section>

@section Scripts {
    <script>
        (function () {
            const input = document.getElementById("profile-photo-input");
            const link = document.getElementById("profile-photo-link");

            if (link && input) {
                link.addEventListener("click", function (e) {
                    e.preventDefault();
                    input.click();
                });
            }
        })();
    </script>
}
