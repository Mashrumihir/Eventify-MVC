@model Eventify.ViewModels.EventDetailsViewModel
@{
    Layout = "_AttendLayout";
    ViewData["Title"] = "Event Details";
    var defaultPrice = Model.TicketOptions.FirstOrDefault()?.Price ?? (Model.Event.Price > 0 ? Model.Event.Price : 0);
}

@section PageStyles {
    <style>
        .ed-content { padding: 16px; background: #eceff3; min-height: calc(100vh - 58px); }
        .ed-grid { display: grid; grid-template-columns: 1fr 300px; gap: 12px; align-items: start; }
        .ed-panel { background: #f8fafc; border: 1px solid #e4e7ec; border-radius: 14px; padding: 14px; }
        .ed-hero { position: relative; overflow: hidden; border-radius: 14px; height: 240px; }
        .ed-hero img { width: 100%; height: 100%; object-fit: cover; display: block; }
        .ed-overlay { position: absolute; inset: 0; background: linear-gradient(0deg, rgba(2, 6, 23, .82), rgba(2, 6, 23, .15)); display: flex; flex-direction: column; justify-content: flex-end; padding: 16px; color: #fff; }
        .ed-pill { display: inline-block; background: #3b82f6; color: #fff; padding: 6px 12px; border-radius: 999px; font-size: 12px; margin-bottom: 8px; }
        .ed-hero h1 { margin: 0 0 6px; font-size: 20px; font-weight: 800; }
        .ed-meta { display: flex; gap: 12px; font-size: 13px; color: #dbeafe; }
        .ed-section { margin-top: 10px; }
        .ed-section h2 { margin: 0 0 8px; font-size: 22px; font-weight: 800; }
        .ed-line { margin: 0 0 6px; color: #334155; display: flex; align-items: center; gap: 8px; font-size: 14px; }
        .ed-line i { color: #3b82f6; }
        .ed-desc { margin: 8px 0 0; color: #475569; line-height: 1.5; font-size: 14px; }
        .ed-book h3 { margin: 0 0 10px; font-size: 22px; font-weight: 800; }
        .ed-ticket { border: 1px solid #d8dde5; border-radius: 12px; padding: 10px; margin-bottom: 8px; cursor: pointer; }
        .ed-ticket.active { border: 2px solid #3b82f6; background: #f1f6ff; }
        .ed-ticket-top { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 5px; }
        .ed-ticket-top h4 { margin: 0; font-size: 14px; } .ed-ticket-top b { font-size: 18px; }
        .ed-ticket ul { margin: 0; padding-left: 16px; color: #475569; font-size: 12px; line-height: 1.4; }
        .ed-row { display: flex; justify-content: space-between; margin: 5px 0; font-size: 13px; color: #334155; }
        .ed-qty-wrap { margin: 8px 0 2px; }
        .ed-qty-label { margin: 0 0 6px; color: #334155; font-size: 14px; font-weight: 700; }
        .ed-qty { display: inline-flex; gap: 6px; align-items: center; }
        .ed-qty button { width: 30px; height: 30px; border: 1px solid #bfd0e4; border-radius: 8px; background: #f8fbff; color: #466184; font-size: 18px; line-height: 1; cursor: pointer; }
        .ed-qty-input { width: 44px; height: 30px; border: 1px solid #bfd0e4; border-radius: 8px; background: #fff; text-align: center; font-size: 14px; color: #1f3552; }
        .ed-total { margin-top: 8px; padding-top: 8px; border-top: 1px solid #e2e8f0; font-size: 18px; font-weight: 800; }
        .ed-pay { width: 100%; margin-top: 12px; height: 42px; border: 0; border-radius: 10px; background: linear-gradient(90deg, #3b82f6, #06b6d4); color: #fff; font-size: 15px; font-weight: 700; cursor: pointer; }
        @@media (max-width: 1120px) { .ed-grid { grid-template-columns: 1fr; } }
    </style>
}

<section class="ed-content">
    <div class="ed-grid">
        <div>
            <article class="ed-hero">
                <img src="@Model.Event.ImageUrl" alt="@Model.Event.Title" />
                <div class="ed-overlay">
                    <span class="ed-pill">@Model.Event.Category</span>
                    <h1>@Model.Event.Title</h1>
                    <div class="ed-meta">
                        <span><i class="bi bi-star-fill"></i> @Model.Event.Rating.ToString("0.0")</span>
                        <span><i class="bi bi-people-fill"></i> @Model.Event.AttendingCount attending</span>
                    </div>
                </div>
            </article>

            <article class="ed-panel ed-section">
                <h2>Event Details</h2>
                <p class="ed-line"><i class="bi bi-calendar3"></i> @Model.Event.StartDateTime.ToString("MMMM d, yyyy")</p>
                <p class="ed-line"><i class="bi bi-geo-alt-fill"></i> @Model.Event.Location</p>
                <p class="ed-line"><i class="bi bi-clock-fill"></i> @Model.Event.StartDateTime.ToString("h:mm tt") - @Model.Event.StartDateTime.AddHours(9).ToString("h:mm tt")</p>
                <p class="ed-desc">@Model.Event.Description</p>
            </article>

        </div>

        <aside class="ed-panel ed-book">
            <h3>Book Tickets</h3>
            @if (Model.TicketOptions.Count == 0)
            {
                <div class="ed-ticket active" data-name="Regular" data-price="@defaultPrice">
                    <div class="ed-ticket-top"><h4>Regular</h4><b>₹@defaultPrice.ToString("0")</b></div>
                </div>
            }
            else
            {
                @foreach (var t in Model.TicketOptions)
                {
                    var features = (t.Features ?? string.Empty).Split('|', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
                    <div class="ed-ticket @(t == Model.TicketOptions.First() ? "active" : "")" data-name="@t.Name" data-price="@t.Price">
                        <div class="ed-ticket-top"><h4>@t.Name</h4><b>₹@t.Price.ToString("0")</b></div>
                        @if (features.Length > 0)
                        {
                            <ul>
                                @foreach (var f in features.Take(4))
                                {
                                    <li>@f</li>
                                }
                            </ul>
                        }
                    </div>
                }
            }
            <div class="ed-qty-wrap">
                <p class="ed-qty-label">Quantity</p>
                <div class="ed-qty">
                    <button id="qtyMinus" type="button">-</button>
                    <input id="qtyInput" class="ed-qty-input" type="text" value="1" readonly />
                    <button id="qtyPlus" type="button">+</button>
                </div>
            </div>
            <div class="ed-row ed-total"><span>Total</span><strong id="totalValue">₹@defaultPrice.ToString("0.00")</strong></div>
            <button id="payBtn" class="ed-pay" type="button">Proceed to Payment</button>
        </aside>
    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const tickets = Array.from(document.querySelectorAll(".ed-ticket"));
            const totalValue = document.getElementById("totalValue");
            const payBtn = document.getElementById("payBtn");
            const qtyInput = document.getElementById("qtyInput");
            const qtyMinus = document.getElementById("qtyMinus");
            const qtyPlus = document.getElementById("qtyPlus");
            let selectedPrice = Number((tickets[0] && tickets[0].dataset.price) || @defaultPrice);
            let selectedName = (tickets[0] && tickets[0].dataset.name) || "Regular";
            let qty = 1;
            function recalc() {
                totalValue.textContent = "₹" + (selectedPrice * qty).toFixed(2);
                if (qtyInput) qtyInput.value = qty.toString();
            }
            if (qtyMinus) {
                qtyMinus.addEventListener("click", function () {
                    qty = Math.max(1, qty - 1);
                    recalc();
                });
            }
            if (qtyPlus) {
                qtyPlus.addEventListener("click", function () {
                    qty = Math.min(10, qty + 1);
                    recalc();
                });
            }
            tickets.forEach(function (ticket) {
                ticket.addEventListener("click", function () {
                    tickets.forEach(function (t) { t.classList.remove("active"); });
                    ticket.classList.add("active");
                    selectedPrice = Number(ticket.dataset.price || selectedPrice);
                    selectedName = ticket.dataset.name || selectedName;
                    recalc();
                });
            });
            payBtn.addEventListener("click", function () {
                if (selectedPrice <= 0) {
                    window.location.href = "/Attend/BookFree?eventId=@Model.Event.Id&ticket=" + encodeURIComponent(selectedName) + "&qty=" + qty;
                    return;
                }
                window.location.href = "/Attend/Payment/@Model.Event.Id?ticket=" + encodeURIComponent(selectedName) + "&price=" + encodeURIComponent(selectedPrice) + "&qty=" + qty;
            });
            recalc();
        });
    </script>
}
