@model Eventify.ViewModels.AttendReviewsViewModel
@{
    Layout = "_AttendLayout";
    ViewData["Title"] = "My Reviews";
}

@section PageStyles {
    <style>
        .rv-wrap { padding: 22px 24px; background: #d4dbe5; min-height: calc(100vh - 58px); }
        .rv-title { margin: 0; color: #1b2a42; font-size: 52px; line-height: 1.03; font-weight: 800; }
        .rv-sub { margin: 6px 0 14px; color: #607794; font-size: 18px; }
        .rv-list { display: grid; gap: 12px; }

        .rv-card { background: #fff; border: 1px solid #dbe3ef; border-radius: 14px; padding: 14px; display: grid; grid-template-columns: 120px 1fr 120px; gap: 14px; align-items: start; }
        .rv-img { width: 110px; height: 88px; border-radius: 10px; object-fit: cover; border: 1px solid #d5deea; }
        .rv-main h3 { margin: 0; color: #18253d; font-size: 18px; font-weight: 800; }
        .rv-stars { margin-top: 4px; color: #eab308; font-size: 12px; letter-spacing: 1px; }
        .rv-main p { margin: 8px 0 10px; color: #4f6788; font-size: 14px; line-height: 1.5; }
        .rv-links { display: flex; gap: 14px; font-size: 13px; align-items: center; }
        .rv-links a { text-decoration: none; }
        .rv-links .edit { color: #2563eb; }
        .rv-links .del { color: #ef4444; border: 0; background: transparent; padding: 0; cursor: pointer; font-size: 13px; }
        .rv-date { color: #6b7280; font-size: 14px; text-align: right; white-space: nowrap; }
        .rv-date i { margin-right: 6px; color: #6b7280; }

        .rv-pending { margin-top: 16px; background: #d9e8f0; border: 1px solid #cddfeb; border-radius: 14px; padding: 14px; }
        .rv-pending h2 { margin: 0 0 10px; color: #1d2b44; font-size: 22px; font-weight: 800; }
        .rv-wait-list { display: grid; gap: 10px; }
        .rv-wait { background: #fff; border: 1px solid #dbe3ef; border-radius: 12px; padding: 10px; display: grid; grid-template-columns: 90px 1fr 120px; gap: 12px; align-items: center; }
        .rv-wait img { width: 82px; height: 62px; border-radius: 8px; object-fit: cover; }
        .rv-wait h4 { margin: 0; color: #1e2c45; font-size: 16px; font-weight: 800; }
        .rv-wait p { margin: 2px 0 0; color: #667f9e; font-size: 14px; }
        .rv-review-btn { height: 40px; border: 0; border-radius: 10px; color: #fff; font-size: 16px; font-weight: 700; background: linear-gradient(90deg, #3b82f6, #06b6d4); cursor: pointer; width: 100%; text-decoration: none; display: inline-flex; align-items: center; justify-content: center; }
        .rv-empty { background: #fff; border: 1px solid #dbe3ef; border-radius: 12px; text-align: center; color: #607794; padding: 18px; font-size: 15px; }

        @@media (max-width: 900px) {
            .rv-wrap { padding: 12px; }
            .rv-title { font-size: 36px; }
            .rv-sub { font-size: 14px; }
            .rv-card { grid-template-columns: 1fr; }
            .rv-date { text-align: left; }
            .rv-wait { grid-template-columns: 1fr; }
        }
    </style>
}

<section class="rv-wrap">
    <h1 class="rv-title">My Reviews</h1>
    <p class="rv-sub">Your feedback helps others discover great events</p>

    @if (Model.Reviews.Count == 0)
    {
        <div class="rv-empty">No reviews yet.</div>
    }
    else
    {
        <div class="rv-list">
            @foreach (var item in Model.Reviews)
            {
                var image = string.IsNullOrWhiteSpace(item.ImageUrl)
                    ? "https://images.unsplash.com/photo-1492684223066-81342ee5ff30?auto=format&fit=crop&w=800&q=80"
                    : item.ImageUrl;
                var filled = Math.Max(0, Math.Min(5, item.Rating));
                var empty = 5 - filled;
                <article class="rv-card">
                    <img class="rv-img" src="@image" alt="@item.EventTitle" />
                    <div class="rv-main">
                        <h3>@item.EventTitle</h3>
                        <div class="rv-stars">
                            @for (var i = 0; i < filled; i++)
                            {
                                @Html.Raw("&#9733;")
                            }
                            @for (var i = 0; i < empty; i++)
                            {
                                @Html.Raw("&#9734;")
                            }
                        </div>
                        <p>@item.Comment</p>
                        <div class="rv-links">
                            <a class="edit" href="/Attend/WriteReview?reviewId=@item.ReviewId">Edit Review</a>
                            <form method="post" action="@Url.Action("DeleteAttendReview", "Attend")">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.ReviewId" />
                                <button class="del" type="submit">Delete Review</button>
                            </form>
                        </div>
                    </div>
                    <div class="rv-date"><i class="bi bi-calendar3"></i>@item.ReviewedAt.ToString("MMM d, yyyy")</div>
                </article>
            }
        </div>
    }

    <section class="rv-pending">
        <h2>Events Waiting for Your Review</h2>
        @if (Model.Pending.Count == 0)
        {
            <div class="rv-empty">You are all caught up.</div>
        }
        else
        {
            <div class="rv-wait-list">
                @foreach (var item in Model.Pending)
                {
                    var image = string.IsNullOrWhiteSpace(item.ImageUrl)
                        ? "https://images.unsplash.com/photo-1514525253161-7a46d19cd819?auto=format&fit=crop&w=800&q=80"
                        : item.ImageUrl;
                    <article class="rv-wait">
                        <img src="@image" alt="@item.EventTitle" />
                        <div>
                            <h4>@item.EventTitle</h4>
                            <p>Attended on @item.AttendedOn.ToString("MMM d, yyyy")</p>
                        </div>
                        <a class="rv-review-btn" href="/Attend/WriteReview?eventId=@item.EventId">Review</a>
                    </article>
                }
            </div>
        }
    </section>
</section>
