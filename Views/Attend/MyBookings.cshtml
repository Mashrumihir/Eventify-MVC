@model Eventify.ViewModels.MyBookingsViewModel
@{
    Layout = "_AttendLayout";
    ViewData["Title"] = "My Bookings";
}

@section PageStyles {
    <style>
        .mb-wrap { padding: 16px 14px; background: #cfd7e2; min-height: calc(100vh - 58px); }
        .mb-title { margin: 0; font-size: 20px; font-weight: 800; color: #152846; }
        .mb-sub { margin: 1px 0 10px; color: #5f7493; font-size: 12px; }

        .mb-tabs { display: flex; gap: 16px; border-bottom: 1px solid #d9e1ec; margin-bottom: 10px; }
        .mb-tab { padding: 8px 0; color: #5c708f; text-decoration: none; font-size: 10px; font-weight: 600; border-bottom: 2px solid transparent; margin-bottom: -1px; }
        .mb-tab.active { color: #2563eb; border-color: #2563eb; }

        .mb-list { display: grid; gap: 8px; }
        .mb-card {
            background: #fff;
            border: 1px solid #dbe3ef;
            border-radius: 12px;
            padding: 10px;
            display: grid;
            grid-template-columns: 64px 1fr 170px 110px;
            gap: 10px;
            align-items: center;
        }

        .mb-thumb { width: 60px; height: 60px; border-radius: 8px; object-fit: cover; border: 1px solid #d5deea; }
        .mb-main h3 { margin: 0; color: #17263f; font-size: 11px; font-weight: 800; line-height: 1.2; }
        .mb-badge { display: inline-flex; align-items: center; gap: 4px; margin-top: 3px; padding: 2px 7px; border-radius: 999px; font-size: 8px; font-weight: 700; }
        .mb-badge.confirmed { background: #dcfce7; color: #166534; }
        .mb-badge.canceled { background: #fee2e2; color: #b91c1c; }
        .mb-row { margin-top: 4px; display: flex; gap: 10px; flex-wrap: wrap; color: #536a89; font-size: 8px; }
        .mb-row i { color: #2563eb; margin-right: 4px; }
        .mb-price { color: #2563eb; font-weight: 800; margin-left: 5px; }
        .mb-price.free { color: #16a34a; }

        .mb-side p { margin: 4px 0; color: #4f6687; font-size: 8px; }
        .mb-side i { color: #3b82f6; margin-right: 4px; }
        .mb-access i.vip { color: #eab308; }
        .mb-access i.premium { color: #a855f7; }
        .mb-access i.standard { color: #22c55e; }

        .mb-actions { text-align: right; }
        .mb-booking-id { color: #9ca3af; font-size: 8px; margin-bottom: 4px; }
        .mb-btns { display: grid; justify-items: end; gap: 4px; }
        .mb-btn {
            height: 24px;
            min-width: 70px;
            border-radius: 7px;
            border: 1px solid transparent;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 8px;
            font-weight: 700;
            cursor: pointer;
            padding: 0 10px;
            background: #fff;
        }
        .mb-btn.show { color: #2563eb; border-color: #93c5fd; background: #eff6ff; }
        .mb-btn.primary { background: #2563eb; color: #fff; }
        .mb-btn.danger { border-color: #ef4444; color: #ef4444; }
        .mb-btn.gray { background: #6b7280; color: #fff; cursor: default; }

        .mb-empty { background: #fff; border: 1px solid #dde4ef; border-radius: 12px; padding: 18px; color: #4b5f7c; font-size: 12px; text-align: center; }

        @@media (max-width: 1100px) {
            .mb-card { grid-template-columns: 64px 1fr; }
            .mb-side, .mb-actions { grid-column: 2 / -1; }
            .mb-actions { text-align: left; }
            .mb-btns { justify-items: start; }
        }
        @@media (max-width: 700px) {
            .mb-wrap { padding: 10px; }
            .mb-card { grid-template-columns: 1fr; }
            .mb-side, .mb-actions { grid-column: auto; }
        }
    </style>
}

<section class="mb-wrap">
    <h1 class="mb-title">My Bookings</h1>
    <p class="mb-sub">Manage and view your event tickets</p>

    <div class="mb-tabs">
        <a class="mb-tab @(Model.ActiveTab == "all" ? "active" : "")" href="/Attend/MyBookings?tab=all">All Bookings</a>
        <a class="mb-tab @(Model.ActiveTab == "upcoming" ? "active" : "")" href="/Attend/MyBookings?tab=upcoming">Upcoming</a>
        <a class="mb-tab @(Model.ActiveTab == "canceled" ? "active" : "")" href="/Attend/MyBookings?tab=canceled">Canceled</a>
    </div>

    @if (Model.Items.Count == 0)
    {
        <div class="mb-empty">No bookings found.</div>
    }
    else
    {
        <div class="mb-list">
            @foreach (var item in Model.Items)
            {
                var image = string.IsNullOrWhiteSpace(item.ImageUrl)
                    ? "https://images.unsplash.com/photo-1492684223066-81342ee5ff30?auto=format&fit=crop&w=600&q=80"
                    : item.ImageUrl;
                var accessIconClass = item.AccessLabel.Contains("Premium") ? "premium" : item.AccessLabel.Contains("VIP") ? "vip" : "standard";
                var isFree = item.Price <= 0;
                var ticketAmount = item.Price * item.Quantity;
                <article class="mb-card">
                    <img class="mb-thumb" src="@image" alt="@item.EventTitle" />

                    <div class="mb-main">
                        <h3>@item.EventTitle</h3>
                        <span class="mb-badge @(item.IsCanceled ? "canceled" : "confirmed")">
                            <i class="bi @(item.IsCanceled ? "bi-x-circle-fill" : "bi-check-circle-fill")"></i>
                            @(item.IsCanceled ? "Canceled" : "Confirmed")
                        </span>
                        <div class="mb-row">
                            <span><i class="bi bi-calendar3"></i>@item.EventDate.ToString("MMMM d, yyyy")</span>
                            <span><i class="bi bi-geo-alt-fill" style="color:#ef4444;"></i>@item.Location</span>
                        </div>
                        <div class="mb-row">
                            <span>@item.Quantity x @item.TicketLabel</span>
                            <span class="mb-price @(isFree ? "free" : "")">@(isFree ? "Free" : $"₹{ticketAmount:0.00}")</span>
                        </div>
                    </div>

                    <div class="mb-side">
                        <p><i class="bi bi-clock"></i>@item.TimeRange</p>
                        <p class="mb-access"><i class="bi bi-ticket-perforated @accessIconClass"></i>@item.AccessLabel</p>
                    </div>

                    <div class="mb-actions">
                        <div class="mb-booking-id">Booking ID: @item.BookingCode</div>
                        <div class="mb-btns">
                            <a class="mb-btn show"
                               href="@Url.Action("BookingInvoice", "Attend", new { code = item.BookingCode })">
                                Show
                            </a>
                            @if (item.IsCanceled)
                            {
                                <span class="mb-btn gray">Refunded</span>
                            }
                            else
                            {
                                <a class="mb-btn primary"
                                   href="@Url.Action("DownloadInvoicePdf", "Attend", new { id = item.EventId, ticket = item.TicketLabel, total = ticketAmount, qty = item.Quantity, bookingId = item.BookingCode })">
                                    Download
                                </a>
                                <form method="post" action="@Url.Action("CancelBooking", "Attend")">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <input type="hidden" name="tab" value="@Model.ActiveTab" />
                                    <button class="mb-btn danger" type="submit">Cancel</button>
                                </form>
                            }
                        </div>
                    </div>
                </article>
            }
        </div>
    }
</section>
