@model Eventify.ViewModels.BookingInvoiceViewModel
@{
    Layout = "_AttendLayout";
    ViewData["Title"] = "Tax Invoice";
}

@section PageStyles {
    <style>
        .iv-wrap { background: #ccd5e1; min-height: calc(100vh - 58px); padding: 14px; }
        .iv-top { max-width: 820px; margin: 0 auto 8px; display: flex; justify-content: space-between; align-items: center; }
        .iv-back { color: #1f3f6f; text-decoration: none; font-size: 10px; font-weight: 600; }
        .iv-pdf { background: linear-gradient(90deg, #3b82f6, #06b6d4); color: #fff; text-decoration: none; font-size: 10px; font-weight: 700; border-radius: 7px; height: 28px; padding: 0 14px; display: inline-flex; align-items: center; gap: 6px; }

        .iv-card { max-width: 820px; margin: 0 auto; background: #fff; border: 1px solid #dbe3ef; border-radius: 14px; box-shadow: 0 10px 20px rgba(15,23,42,.08); padding: 12px; }
        .iv-head { display: flex; justify-content: space-between; gap: 8px; border-bottom: 1px solid #dbe3ef; padding-bottom: 8px; }
        .iv-title { margin: 0; color: #122743; font-weight: 800; font-size: 40px; line-height: 1.05; }
        .iv-company { color: #5f7493; font-size: 10px; margin-top: 2px; }
        .iv-head-right { text-align: right; color: #3d5677; font-size: 10px; line-height: 1.5; }
        .iv-head-right strong { color: #122743; }

        .iv-grid { margin-top: 8px; display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
        .iv-box { border: 1px solid #d4deeb; border-radius: 10px; padding: 10px; }
        .iv-box h3 { margin: 0 0 6px; color: #102742; font-size: 11px; font-weight: 800; }
        .iv-box p { margin: 0; color: #486284; font-size: 10px; line-height: 1.5; }

        .iv-table { margin-top: 8px; border: 1px solid #d4deeb; border-radius: 10px; overflow: hidden; }
        .iv-row { display: grid; grid-template-columns: 1fr 80px 120px 120px; }
        .iv-row > div { padding: 9px 10px; font-size: 10px; color: #1f3552; }
        .iv-row.head { background: #f3f7fc; font-weight: 700; border-bottom: 1px solid #dbe3ef; }
        .iv-row.body { background: #fff; }

        .iv-total-wrap { margin-top: 10px; display: flex; justify-content: flex-end; }
        .iv-total { width: 290px; border: 1px solid #d4deeb; border-radius: 10px; padding: 8px; }
        .iv-line { display: flex; justify-content: space-between; color: #234264; font-size: 10px; margin: 3px 0; }
        .iv-line.discount { color: #059669; }
        .iv-line.total { border-top: 1px solid #dbe3ef; margin-top: 6px; padding-top: 6px; font-size: 12px; font-weight: 800; color: #1d4ed8; }

        .iv-foot { margin-top: 10px; border-top: 1px solid #dbe3ef; padding-top: 8px; text-align: center; color: #607794; font-size: 9px; line-height: 1.6; }

        @@media (max-width: 900px) {
            .iv-title { font-size: 28px; }
            .iv-grid { grid-template-columns: 1fr; }
            .iv-row { grid-template-columns: 1fr 60px 90px 90px; }
            .iv-total { width: 100%; }
        }
    </style>
}

<section class="iv-wrap">
    <div class="iv-top">
        <a class="iv-back" href="/Attend/MyBookings"><i class="bi bi-arrow-left"></i> Back to My Bookings</a>
        <a class="iv-pdf"
           href="@Url.Action("DownloadInvoicePdf", "Attend", new { id = Model.EventId, ticket = Model.TicketName, total = Model.Subtotal, qty = Model.Quantity, bookingId = Model.BookingCode })">
            <i class="bi bi-download"></i> Download PDF
        </a>
    </div>

    <article class="iv-card">
        <div class="iv-head">
            <div>
                <h1 class="iv-title">Tax Invoice</h1>
                <div class="iv-company">Eventify Pvt. Ltd.</div>
            </div>
            <div class="iv-head-right">
                <div><strong>@Model.InvoiceNumber</strong></div>
                <div>Booking ID : @Model.BookingCode</div>
                <div>Issued: @Model.IssuedOn.ToString("dd MMM yyyy")</div>
            </div>
        </div>

        <div class="iv-grid">
            <div class="iv-box">
                <h3>Bill To</h3>
                <p>@Model.UserName</p>
                <p>@Model.UserEmail</p>
                <p>@Model.UserPhone</p>
            </div>
            <div class="iv-box">
                <h3>Event Details</h3>
                <p>@Model.EventTitle</p>
                <p>@Model.EventDate.ToString("MMMM d, yyyy")</p>
                <p>@Model.EventTime</p>
                <p>@Model.EventLocation</p>
            </div>
        </div>

        <div class="iv-table">
            <div class="iv-row head">
                <div>Description</div>
                <div>Qty</div>
                <div>Unit Price</div>
                <div>Line Total</div>
            </div>
            <div class="iv-row body">
                <div>@Model.TicketName • @Model.EventTitle</div>
                <div>@Model.Quantity</div>
                <div>₹@Model.UnitPrice.ToString("0.00")</div>
                <div>₹@Model.Subtotal.ToString("0.00")</div>
            </div>
        </div>

        <div class="iv-total-wrap">
            <div class="iv-total">
                <div class="iv-line"><span>Subtotal</span><span>₹@Model.Subtotal.ToString("0.00")</span></div>
                <div class="iv-line discount"><span>Discount</span><span>-₹@Model.Discount.ToString("0.00")</span></div>
                <div class="iv-line total"><span>Total</span><span>₹@Model.Total.ToString("0.00")</span></div>
            </div>
        </div>

        <div class="iv-foot">
            Thank you for booking with Eventify.<br />
            This is a system-generated invoice.
        </div>
    </article>
</section>
