@{
    ViewData["Title"] = "About Us";
}

<style>
    .au-page {
        --au-card: rgba(255, 255, 255, 0.72);
        --au-border: rgba(158, 184, 224, 0.45);
        --au-text: #16365f;
        --au-sub: #557197;
        --au-accent: #245dcf;
        --au-accent-2: #1ea8c9;
        --au-shadow: 0 16px 40px rgba(28, 62, 118, 0.14);
        max-width: 1120px;
        margin: 22px auto 40px;
        padding: 0 16px;
        color: var(--au-text);
    }

    .au-back-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 14px;
        margin: 0 0 12px;
        border-radius: 999px;
        border: 1px solid #c9dbf8;
        background: #f6faff;
        color: #1f4478;
        text-decoration: none;
        font-size: 13px;
        font-weight: 700;
        transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
    }

    .au-back-link:hover {
        transform: translateY(-1px);
        border-color: #b7cff3;
        box-shadow: 0 8px 18px rgba(31, 73, 138, .14);
        color: #163a67;
    }

    .au-back-link i { font-size: 13px; }

    .au-hero {
        background: linear-gradient(145deg, #e6efff, #f3f9ff);
        border: 1px solid #d3e2fb;
        border-radius: 22px;
        padding: 18px;
        margin-bottom: 14px;
    }

    .au-title { margin: 0; font-size: 34px; font-weight: 800; letter-spacing: .2px; }
    .au-lead { margin: 8px 0 0; font-size: 15px; color: var(--au-sub); line-height: 1.55; }

    .au-section { margin-top: 16px; }
    .au-section h2 { margin: 0 0 10px; font-size: 24px; color: #1a3b6b; font-weight: 800; }

    .au-story { display: grid; grid-template-columns: 1fr; gap: 14px; align-items: stretch; }

    .au-glass {
        background: var(--au-card);
        border: 1px solid var(--au-border);
        backdrop-filter: blur(8px);
        border-radius: 18px;
        padding: 16px;
        box-shadow: var(--au-shadow);
    }

    .au-story p { margin: 0; font-size: 14px; line-height: 1.65; color: #34547e; }

    .au-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

    .au-card {
        background: #fff;
        border: 1px solid #d8e4f6;
        border-radius: 16px;
        padding: 14px;
        transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
    }

    .au-card:hover { transform: translateY(-2px); box-shadow: 0 14px 30px rgba(29, 76, 145, .14); border-color: #bdd2f4; }

    .au-card-head { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; font-weight: 800; color: #1f416f; }

    .au-icon {
        width: 28px; height: 28px; border-radius: 999px; display: inline-flex; align-items: center; justify-content: center;
        color: #fff; font-size: 13px; background: linear-gradient(135deg, var(--au-accent), var(--au-accent-2));
    }

    .au-card p { margin: 0; color: #4b688f; font-size: 13px; line-height: 1.55; }

    .au-features { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 10px; }

    .au-feature {
        background: #fff; border: 1px solid #d8e4f6; border-radius: 14px; padding: 12px;
        transition: box-shadow .2s ease, transform .2s ease;
    }

    .au-feature:hover { box-shadow: 0 0 0 1px #cde0ff inset, 0 12px 28px rgba(30, 94, 180, .16); transform: translateY(-2px); }
    .au-feature h3 { margin: 8px 0 0; font-size: 14px; color: #213f6d; }

    .au-team { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 10px; }

    .au-member { background: #fff; border: 1px solid #d8e4f6; border-radius: 14px; padding: 12px; text-align: center; }

    .au-avatar {
        width: 66px; height: 66px; border-radius: 999px; margin: 0 auto 8px; display: flex; align-items: center; justify-content: center;
        font-size: 20px; font-weight: 800; color: #fff; background: linear-gradient(145deg, #2e61c5, #2ab1cd);
    }

    .au-member h3 { margin: 0; font-size: 14px; color: #1d3c6a; }
    .au-member p { margin: 5px 0 0; font-size: 12px; color: #5a7598; }

    .au-stats { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 10px; }

    .au-stat { background: #fff; border: 1px solid #d8e4f6; border-radius: 14px; padding: 12px; display: flex; align-items: center; gap: 9px; }
    .au-stat strong { display: block; font-size: 17px; color: #1c3d6f; }
    .au-stat span { font-size: 12px; color: #5f7699; }

    .au-join {
        margin-top: 14px; border: 1px solid #d4e0f3; background: #fff; border-radius: 16px; padding: 16px; text-align: center;
    }

    .au-join h2 { margin: 0; font-size: 24px; color: #1a3f73; }
    .au-join p { margin: 7px 0 12px; color: #557197; font-size: 14px; }
    .au-join-actions { display: inline-flex; gap: 8px; flex-wrap: wrap; justify-content: center; }

    .au-join-btn { text-decoration: none; border-radius: 999px; padding: 9px 14px; font-size: 13px; font-weight: 700; }
    .au-join-btn.primary { color: #fff; background: linear-gradient(135deg, #245dcf, #1ea8c9); }
    .au-join-btn.soft { color: #204370; border: 1px solid #bfd3ef; background: #f4f8ff; }

    .au-cta {
        margin-top: 16px; border-radius: 18px; padding: 20px; background: linear-gradient(140deg, #245ecf, #1ea7c9); color: #fff; text-align: center;
    }

    .au-cta h2 { margin: 0; font-size: 28px; color: #fff; }
    .au-cta p { margin: 8px 0 14px; font-size: 14px; color: rgba(255, 255, 255, .9); }

    .au-cta-actions { display: inline-flex; gap: 8px; flex-wrap: wrap; justify-content: center; }
    .au-btn { text-decoration: none; border-radius: 999px; padding: 9px 14px; font-size: 13px; font-weight: 700; }
    .au-btn.white { background: #fff; color: #1f4f9a; }
    .au-btn.outline { border: 1px solid rgba(255, 255, 255, .8); color: #fff; }

    .au-footer { margin-top: 16px; background: #0d1f4a; color: #dce7ff; border-radius: 16px; overflow: hidden; }
    .au-footer-top { display: grid; grid-template-columns: 1.3fr 1fr 1fr 1fr; gap: 16px; padding: 16px; }

    .au-footer h4, .au-footer h5 { margin: 0 0 8px; color: #fff; font-weight: 700; font-size: 14px; }
    .au-footer p, .au-footer a { margin: 0 0 6px; font-size: 12px; color: #c9d9fb; text-decoration: none; display: block; }
    .au-footer a:hover { color: #fff; }

    .au-footer-socials { display: flex; gap: 6px; margin-top: 8px; }
    .au-footer-socials a {
        width: 22px; height: 22px; border-radius: 999px; border: 1px solid rgba(255,255,255,.25);
        display: inline-flex; align-items: center; justify-content: center; font-size: 11px; margin: 0;
    }

    .au-footer-bottom {
        border-top: 1px solid rgba(255,255,255,.14); padding: 10px 16px; display: flex; justify-content: space-between;
        gap: 10px; font-size: 11px; color: #b9c9ec;
    }

    @@media (max-width: 980px) {
        .au-features { grid-template-columns: 1fr 1fr; }
        .au-team { grid-template-columns: 1fr 1fr; }
        .au-stats { grid-template-columns: 1fr 1fr; }
        .au-footer-top { grid-template-columns: 1fr 1fr; }
    }

    @@media (max-width: 640px) {
        .au-title { font-size: 28px; }
        .au-grid-2, .au-features, .au-team, .au-stats { grid-template-columns: 1fr; }
        .au-footer-top { grid-template-columns: 1fr; }
        .au-footer-bottom { flex-direction: column; }
    }
</style>

<div class="au-page">
    <a class="au-back-link" href="javascript:history.back()">
        <i class="bi bi-arrow-left"></i>
        <span>Go Back</span>
    </a>

    <section class="au-hero">
        <h1 class="au-title">About Us</h1>
        <p class="au-lead">Eventify is a platform built to simplify how people create, manage, and attend events.</p>
    </section>

    <section class="au-section">
        <h2>Our Story</h2>
        <div class="au-story">
            <article class="au-glass">
                <p>
                    Eventify was built with one simple goal — to make event management effortless.
                    From college fests to corporate conferences, we noticed how messy planning and booking could get.
                    So we created a platform that brings everything together — organizing, booking, payments, and analytics — in one smooth experience.
                    <br /><br />
                    What started as a simple idea is now a growing platform helping organizers and attendees connect better than ever.
                </p>
            </article>
        </div>
    </section>

    <section class="au-section">
        <h2>Mission &amp; Vision</h2>
        <div class="au-grid-2">
            <article class="au-card">
                <div class="au-card-head"><span class="au-icon">M</span> Mission</div>
                <p>To simplify event management through smart technology and seamless user experience.</p>
            </article>
            <article class="au-card">
                <div class="au-card-head"><span class="au-icon">V</span> Vision</div>
                <p>To become the go-to platform for events worldwide, empowering creators and connecting communities.</p>
            </article>
        </div>
    </section>

    <section class="au-section">
        <h2>What We Offer</h2>
        <div class="au-features">
            <article class="au-feature"><span class="au-icon">1</span><h3>Easy Event Creation</h3></article>
            <article class="au-feature"><span class="au-icon">2</span><h3>Smart Ticket Booking</h3></article>
            <article class="au-feature"><span class="au-icon">3</span><h3>Secure Payment Integration</h3></article>
            <article class="au-feature"><span class="au-icon">4</span><h3>Real-time Notifications</h3></article>
            <article class="au-feature"><span class="au-icon">5</span><h3>Analytics Dashboard</h3></article>
            <article class="au-feature"><span class="au-icon">6</span><h3>Multi-role Access (Admin, Organizer, User)</h3></article>
        </div>
    </section>

    <section class="au-section">
        <h2>Our Team</h2>
        <div class="au-team">
            <article class="au-member"><div class="au-avatar">MM</div><h3>Mihir Mashru</h3><p>Founder / Developer</p></article>
            <article class="au-member"><div class="au-avatar">AK</div><h3>Anaya Kapoor</h3><p>UI/UX Designer</p></article>
            <article class="au-member"><div class="au-avatar">RS</div><h3>Rohan Shah</h3><p>Backend Developer</p></article>
            <article class="au-member"><div class="au-avatar">NP</div><h3>Neha Patel</h3><p>Marketing Lead</p></article>
        </div>
    </section>

    <section class="au-section">
        <h2>Stats / Achievements</h2>
        <div class="au-stats">
            <article class="au-stat"><span class="au-icon">E</span><div><strong>10,000+</strong><span>Events Created</span></div></article>
            <article class="au-stat"><span class="au-icon">U</span><div><strong>50,000+</strong><span>Users</span></div></article>
            <article class="au-stat"><span class="au-icon">O</span><div><strong>2,000+</strong><span>Organizers</span></div></article>
            <article class="au-stat"><span class="au-icon">R</span><div><strong>4.9</strong><span>Average Rating</span></div></article>
        </div>
    </section>
<section class="au-cta">
        <h2>Ready to Create Your Next Event?</h2>
        <p>Start planning in minutes and run your events with confidence.</p>
        <div class="au-cta-actions">
            <a class="au-btn white" href="/">Get Started</a>
            <a class="au-btn outline" href="/Home/Privacy">Contact Us</a>
        </div>
    </section>
</div>




