                <div class="pe-logo">College Carnival RKU</div>
                <div class="pe-logo">Music Mania Live</div>
                <div class="pe-logo">Corporate Expo 2025</div>
                <div class="pe-logo">TechFest 2025</div>
                <div class="pe-logo">Garba Night Ahmedabad</div>
                <div class="pe-logo">Startup Summit India</div>
                <div class="pe-logo">College Carnival RKU</div>
