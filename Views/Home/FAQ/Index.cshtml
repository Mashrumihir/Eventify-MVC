Q@{
    ViewData["Title"] = "FAQ";
}

<style>
    .faq-page {
        --faq-bg: #f3f7ff;
        --faq-card: #ffffff;
        --faq-border: #d7e4fa;
        --faq-text: #183d6a;
        --faq-sub: #587397;
        --faq-accent: #2560d0;
        max-width: 860px;
        margin: 24px auto 48px;
        padding: 0 16px;
        color: var(--faq-text);
    }

    .faq-back-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 14px;
        margin: 0 0 12px;
        border-radius: 999px;
        border: 1px solid #c9dbf8;
        background: #f6faff;
        color: #1f4478;
        text-decoration: none;
        font-size: 13px;
        font-weight: 700;
        transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
    }

    .faq-back-link:hover {
        transform: translateY(-1px);
        border-color: #b7cff3;
        box-shadow: 0 8px 18px rgba(31, 73, 138, .14);
        color: #163a67;
    }

    .faq-back-link i { font-size: 13px; }

    .faq-head {
        background: linear-gradient(145deg, #e8f1ff, #f6faff);
        border: 1px solid #d3e2fb;
        border-radius: 20px;
        padding: 20px;
        margin-bottom: 14px;
    }

    .faq-head h1 {
        margin: 0;
        font-size: 34px;
        font-weight: 800;
        color: #1b3f71;
    }

    .faq-head p {
        margin: 8px 0 0;
        color: var(--faq-sub);
        font-size: 15px;
    }

    .faq-list {
        display: grid;
        gap: 10px;
    }

    .faq-item {
        border: 1px solid var(--faq-border);
        border-radius: 14px;
        background: var(--faq-card);
        box-shadow: 0 2px 0 rgba(28, 74, 140, .02);
        transition: border-color .2s ease, box-shadow .25s ease, transform .2s ease;
        overflow: hidden;
    }

    .faq-item:hover {
        border-color: #bdd2f7;
        box-shadow: 0 0 0 1px #d4e3ff inset, 0 12px 24px rgba(38, 89, 164, .12);
        transform: translateY(-1px);
    }

    .faq-q {
        width: 100%;
        border: 0;
        background: transparent;
        padding: 14px 16px;
        text-align: left;
        font-size: 15px;
        font-weight: 700;
        color: #1f4478;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        cursor: pointer;
    }

    .faq-q:focus-visible {
        outline: 2px solid #7da9ee;
        outline-offset: -2px;
        border-radius: 12px;
    }

    .faq-icon {
        width: 24px;
        height: 24px;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        background: linear-gradient(135deg, #2b68d6, #21a2c6);
        font-size: 14px;
        font-weight: 800;
        transition: transform .25s ease;
        flex-shrink: 0;
    }

    .faq-item.is-open .faq-icon {
        transform: rotate(180deg);
    }

    .faq-a-wrap {
        max-height: 0;
        opacity: 0;
        overflow: hidden;
        transition: max-height .35s ease, opacity .25s ease;
    }

    .faq-item.is-open .faq-a-wrap {
        opacity: 1;
    }

    .faq-a {
        padding: 0 16px 14px;
        font-size: 14px;
        line-height: 1.6;
        color: #486788;
    }

    .faq-help {
        margin-top: 14px;
        border: 1px solid #cfe0ff;
        border-radius: 16px;
        background: linear-gradient(145deg, #f8fbff, #eef5ff);
        padding: 16px;
        text-align: center;
    }

    .faq-help h3 {
        margin: 0;
        font-size: 22px;
        color: #1b3f71;
    }

    .faq-help p {
        margin: 8px 0 12px;
        color: #5a7598;
        font-size: 14px;
    }

    .faq-help-btn {
        display: inline-block;
        text-decoration: none;
        border-radius: 999px;
        padding: 9px 14px;
        font-size: 13px;
        font-weight: 700;
        color: #fff;
        background: linear-gradient(135deg, #2560d0, #1fa1c6);
    }

    .faq-help small {
        display: block;
        margin-top: 9px;
        color: #5f7a9c;
        font-size: 12px;
    }


    .faq-help-actions {
        display: inline-flex;
        gap: 8px;
        flex-wrap: wrap;
        justify-content: center;
    }

    .faq-chat-trigger {
        display: inline-block;
        border: 1px solid #bfd3ef;
        background: #fff;
        color: #214574;
        text-decoration: none;
        border-radius: 999px;
        padding: 9px 14px;
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
    }

    .faq-chat-widget {
        position: fixed;
        right: 16px;
        bottom: 16px;
        width: min(340px, 92vw);
        border: 1px solid #c9dbf6;
        border-radius: 14px;
        background: #fff;
        box-shadow: 0 16px 30px rgba(24, 68, 134, .24);
        overflow: hidden;
        z-index: 1000;
        opacity: 0;
        transform: translateY(10px) scale(.98);
        pointer-events: none;
        transition: opacity .2s ease, transform .2s ease;
    }

    .faq-chat-widget.show {
        opacity: 1;
        transform: translateY(0) scale(1);
        pointer-events: auto;
    }

    .faq-chat-head {
        padding: 10px 12px;
        color: #fff;
        background: linear-gradient(135deg, #265fd0, #1fa3c7);
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 13px;
        font-weight: 700;
    }

    .faq-chat-close {
        border: 0;
        width: 24px;
        height: 24px;
        border-radius: 999px;
        cursor: pointer;
        color: #1f4f8a;
        background: #fff;
        font-size: 12px;
        line-height: 1;
    }

    .faq-chat-body {
        padding: 10px;
        max-height: 220px;
        overflow: auto;
        background: #f8fbff;
        display: grid;
        gap: 8px;
    }

    .faq-msg {
        max-width: 86%;
        padding: 8px 10px;
        border-radius: 12px;
        font-size: 13px;
        line-height: 1.45;
    }

    .faq-msg.bot {
        color: #23486f;
        background: #e8f0ff;
        border: 1px solid #d2e2fa;
        justify-self: start;
    }

    .faq-msg.user {
        color: #fff;
        background: linear-gradient(135deg, #2a64d2, #1ea5c8);
        justify-self: end;
    }

    .faq-chat-form {
        border-top: 1px solid #dce8fa;
        padding: 8px;
        display: flex;
        gap: 6px;
        background: #fff;
    }

    .faq-chat-form input {
        flex: 1;
        border: 1px solid #c9dcf8;
        border-radius: 999px;
        padding: 8px 10px;
        font-size: 13px;
        outline: none;
    }

    .faq-chat-form input:focus {
        border-color: #89afea;
        box-shadow: 0 0 0 3px rgba(120, 164, 235, .18);
    }

    .faq-chat-form button {
        border: 0;
        border-radius: 999px;
        padding: 8px 12px;
        font-size: 12px;
        font-weight: 700;
        color: #fff;
        background: linear-gradient(135deg, #2660d0, #1fa4c8);
        cursor: pointer;
    }

    .faq-footer {
        margin-top: 18px;
        background: #0d1f4a;
        color: #dce7ff;
        border-radius: 16px;
        overflow: hidden;
    }

    .faq-footer-top {
        display: grid;
        grid-template-columns: 1.3fr 1fr 1fr 1fr;
        gap: 16px;
        padding: 16px;
    }

    .faq-footer h4,
    .faq-footer h5 {
        margin: 0 0 8px;
        color: #fff;
        font-weight: 700;
        font-size: 14px;
    }

    .faq-footer p,
    .faq-footer a {
        margin: 0 0 6px;
        font-size: 12px;
        color: #c9d9fb;
        text-decoration: none;
        display: block;
    }

    .faq-footer a:hover { color: #fff; }

    .faq-top-btn {
        position: fixed;
        left: 16px;
        bottom: 16px;
        width: 40px;
        height: 40px;
        border-radius: 999px;
        border: 1px solid #bcd2f5;
        background: #f4f8ff;
        color: #2a4f80;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 10px 20px rgba(26, 71, 138, .2);
        text-decoration: none;
        opacity: 0;
        transform: translateY(8px);
        pointer-events: none;
        transition: opacity .2s ease, transform .2s ease;
        z-index: 999;
    }

    .faq-top-btn.show {
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
    }
    @@media (max-width: 640px) {
        .faq-head h1 { font-size: 28px; }
        .faq-footer-top { grid-template-columns: 1fr; }
        .faq-q { font-size: 14px; }
    }
</style>

<div class="faq-page">
    <a class="faq-back-link" href="javascript:history.back()">
        <i class="bi bi-arrow-left"></i>
        <span>Go Back</span>
    </a>

    <section class="faq-head">
        <h1>Frequently Asked Questions</h1>
        <p>Everything you need to know about using Eventify.</p>
    </section>

    <section class="faq-list" id="faqList">
        <article class="faq-item">
            <button class="faq-q" type="button" aria-expanded="false">
                <span>1. What is Eventify?</span>
                <span class="faq-icon">+</span>
            </button>
            <div class="faq-a-wrap">
                <div class="faq-a">Eventify is an all-in-one platform to create, manage, and book events easily - from small gatherings to large-scale events.</div>
            </div>
        </article>

        <article class="faq-item">
            <button class="faq-q" type="button" aria-expanded="false">
                <span>2. How can I book an event?</span>
                <span class="faq-icon">+</span>
            </button>
            <div class="faq-a-wrap">
                <div class="faq-a">Simply browse events, select your preferred one, choose tickets, and proceed to payment.</div>
            </div>
        </article>

        <article class="faq-item">
            <button class="faq-q" type="button" aria-expanded="false">
                <span>3. Can I create my own event?</span>
                <span class="faq-icon">+</span>
            </button>
            <div class="faq-a-wrap">
                <div class="faq-a">Yes! Register as an organizer and start creating events with full control over tickets, pricing, and details.</div>
            </div>
        </article>

        <article class="faq-item">
            <button class="faq-q" type="button" aria-expanded="false">
                <span>4. What payment methods are supported?</span>
                <span class="faq-icon">+</span>
            </button>
            <div class="faq-a-wrap">
                <div class="faq-a">We support UPI, debit/credit cards, and net banking (UI simulation in this project).</div>
            </div>
        </article>

        <article class="faq-item">
            <button class="faq-q" type="button" aria-expanded="false">
                <span>5. Can I cancel my booking?</span>
                <span class="faq-icon">+</span>
            </button>
            <div class="faq-a-wrap">
                <div class="faq-a">Yes, bookings can be cancelled based on the event&rsquo;s refund policy set by the organizer.</div>
            </div>
        </article>

        <article class="faq-item">
            <button class="faq-q" type="button" aria-expanded="false">
                <span>6. How do I receive my ticket?</span>
                <span class="faq-icon">+</span>
            </button>
            <div class="faq-a-wrap">
                <div class="faq-a">After successful booking, your ticket will be available in your dashboard with a downloadable QR code.</div>
            </div>
        </article>

        <article class="faq-item">
            <button class="faq-q" type="button" aria-expanded="false">
                <span>7. Is my data secure?</span>
                <span class="faq-icon">+</span>
            </button>
            <div class="faq-a-wrap">
                <div class="faq-a">Absolutely. Eventify ensures secure authentication and safe data handling practices.</div>
            </div>
        </article>

        <article class="faq-item">
            <button class="faq-q" type="button" aria-expanded="false">
                <span>8. How can I contact support?</span>
                <span class="faq-icon">+</span>
            </button>
            <div class="faq-a-wrap">
                <div class="faq-a">You can reach us via the Contact Us page or email support for any queries.</div>
            </div>
        </article>
    </section>

    <section class="faq-help">
        <h3>Still have questions?</h3>
        <p>Need help with anything else? Our team is ready to support you.</p>
        <div class="faq-help-actions">
            <a class="faq-help-btn" href="@Url.Action("Privacy", "Home")">Contact Support</a>
            <button class="faq-chat-trigger" id="faqLiveChatBtn" type="button">Live Chat</button>
        </div>
        <small>We&rsquo;re here to help 24/7</small>
    </section>
</div>

<div class="faq-chat-widget" id="faqChatWidget" aria-live="polite">
    <div class="faq-chat-head">
        <span>Eventify AI Assistant</span>
        <button class="faq-chat-close" id="faqChatCloseBtn" type="button" aria-label="Close chat"><i class="bi bi-x-lg"></i></button>
    </div>
    <div class="faq-chat-body" id="faqChatBody">
        <div class="faq-msg bot">Hi! I am Eventify AI. Ask me anything about bookings, tickets, events, payments, refunds, or support.</div>
    </div>
    <form class="faq-chat-form" id="faqChatForm" action="#" method="post">
        <input id="faqChatInput" type="text" placeholder="Ask your question..." required />
        <button type="submit">Send</button>
    </form>
</div>
<a class="faq-top-btn" id="faqTopBtn" href="#" aria-label="Back to top"><i class="bi bi-arrow-up"></i></a>
<script>
    (function () {
        var items = document.querySelectorAll('.faq-item');
        var faqLiveChatBtn = document.getElementById('faqLiveChatBtn');
        var faqChatWidget = document.getElementById('faqChatWidget');
        var faqChatCloseBtn = document.getElementById('faqChatCloseBtn');
        var faqChatForm = document.getElementById('faqChatForm');
        var faqChatInput = document.getElementById('faqChatInput');
        var faqChatBody = document.getElementById('faqChatBody');
        var faqTopBtn = document.getElementById('faqTopBtn');

        var faqKnowledge = [
            { keys: ['what is eventify', 'eventify', 'platform'], answer: 'Eventify is an all-in-one platform to create, manage, and book events, from small gatherings to large-scale events.' },
            { keys: ['book', 'booking', 'ticket'], answer: 'To book an event, browse events, choose one, select tickets, and proceed to payment.' },
            { keys: ['create', 'organizer', 'organiser', 'my own event'], answer: 'Yes. Register as an organizer and you can create events with full control over tickets, pricing, and details.' },
            { keys: ['payment', 'upi', 'card', 'net banking'], answer: 'Supported payment methods include UPI, debit or credit cards, and net banking (UI simulation in this project).' },
            { keys: ['cancel', 'refund'], answer: 'Bookings can be canceled based on the event refund policy set by the organizer.' },
            { keys: ['receive ticket', 'qr', 'ticket download', 'dashboard'], answer: 'After successful booking, your ticket is available in your dashboard with a downloadable QR code.' },
            { keys: ['data secure', 'security', 'privacy'], answer: 'Yes. Eventify follows secure authentication and safe data handling practices.' },
            { keys: ['support', 'contact', 'help'], answer: 'You can reach support via the Contact Us page or email for queries.' }
        ];

        function normalize(text) {
            return text.toLowerCase().replace(/[^a-z0-9\s]/g, ' ').replace(/\s+/g, ' ').trim();
        }

        function getBotReply(message) {
            var clean = normalize(message);
            var best = { score: 0, answer: null };

            faqKnowledge.forEach(function (entry) {
                var score = 0;
                entry.keys.forEach(function (key) {
                    if (clean.indexOf(key) !== -1) score += Math.max(2, key.split(' ').length);
                });
                if (score > best.score) {
                    best = { score: score, answer: entry.answer };
                }
            });

            if (best.answer) return best.answer;
            return 'I can help with Eventify FAQs like booking, creating events, payments, cancellation, tickets, security, and support. Try asking one of those topics.';
        }

        function appendMsg(role, text) {
            var msg = document.createElement('div');
            msg.className = 'faq-msg ' + role;
            msg.textContent = text;
            faqChatBody.appendChild(msg);
            faqChatBody.scrollTop = faqChatBody.scrollHeight;
        }

        function closeItem(item) {
            var btn = item.querySelector('.faq-q');
            var icon = item.querySelector('.faq-icon');
            var wrap = item.querySelector('.faq-a-wrap');
            item.classList.remove('is-open');
            btn.setAttribute('aria-expanded', 'false');
            icon.textContent = '+';
            wrap.style.maxHeight = '0px';
        }

        function openItem(item) {
            var btn = item.querySelector('.faq-q');
            var icon = item.querySelector('.faq-icon');
            var wrap = item.querySelector('.faq-a-wrap');
            item.classList.add('is-open');
            btn.setAttribute('aria-expanded', 'true');
            icon.textContent = '-';
            wrap.style.maxHeight = wrap.scrollHeight + 'px';
        }

        items.forEach(function (item) {
            var btn = item.querySelector('.faq-q');
            btn.addEventListener('click', function () {
                var isOpen = item.classList.contains('is-open');
                if (isOpen) {
                    closeItem(item);
                } else {
                    openItem(item);
                }
            });
        });

        window.addEventListener('resize', function () {
            items.forEach(function (item) {
                if (item.classList.contains('is-open')) {
                    var wrap = item.querySelector('.faq-a-wrap');
                    wrap.style.maxHeight = wrap.scrollHeight + 'px';
                }
            });
        });


        if (faqTopBtn) {
            faqTopBtn.addEventListener('click', function (event) {
                event.preventDefault();
                window.scrollTo({ top: 0, behavior: 'smooth' });
            });

            function toggleTopBtn() {
                if (window.scrollY > 260) faqTopBtn.classList.add('show');
                else faqTopBtn.classList.remove('show');
            }

            window.addEventListener('scroll', toggleTopBtn, { passive: true });
            toggleTopBtn();
        }
        if (faqLiveChatBtn && faqChatWidget && faqChatCloseBtn && faqChatForm && faqChatInput && faqChatBody) {
            faqLiveChatBtn.addEventListener('click', function () {
                faqChatWidget.classList.add('show');
                faqChatInput.focus();
            });

            faqChatCloseBtn.addEventListener('click', function () {
                faqChatWidget.classList.remove('show');
            });

            faqChatForm.addEventListener('submit', function (event) {
                event.preventDefault();
                var text = faqChatInput.value.trim();
                if (!text) return;

                appendMsg('user', text);
                faqChatInput.value = '';

                var reply = getBotReply(text);
                window.setTimeout(function () {
                    appendMsg('bot', reply);
                }, 350);
            });
        }
    })();
</script>




