@{
    ViewData["Title"] = "Privacy Policy";
}

<style>
    .pp-progress {
        position: fixed;
        top: 0;
        left: 0;
        height: 3px;
        width: 0;
        background: linear-gradient(90deg, #2e66d4, #d09a25);
        z-index: 1000;
        transition: width .12s linear;
    }

    .pp-page {
        --pp-text: #193f70;
        --pp-sub: #5c7698;
        --pp-border: #d5e3f8;
        --pp-gold: #d09a25;
        max-width: 1140px;
        margin: 16px auto 48px;
        padding: 0 16px;
        color: var(--pp-text);
    }

    .pp-nav {
        border: 1px solid var(--pp-border);
        border-radius: 16px;
        padding: 10px 14px;
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        margin-bottom: 12px;
    }

    .pp-brand {
        color: #1d4478;
        text-decoration: none;
        font-weight: 800;
        font-size: 18px;
        display: inline-flex;
        gap: 6px;
        align-items: center;
    }

    .pp-nav-links {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .pp-nav-links a {
        text-decoration: none;
        color: #2a507f;
        font-size: 13px;
        font-weight: 700;
    }

    .pp-back-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 14px;
        margin: 0 0 12px;
        border-radius: 999px;
        border: 1px solid #c9dbf8;
        background: #f6faff;
        color: #1f4478;
        text-decoration: none;
        font-size: 13px;
        font-weight: 700;
        transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
    }

    .pp-back-link:hover {
        transform: translateY(-1px);
        border-color: #b7cff3;
        box-shadow: 0 8px 18px rgba(31, 73, 138, .14);
        color: #163a67;
    }

    .pp-back-link i { font-size: 13px; }

    .pp-header {
        border: 1px solid var(--pp-border);
        border-radius: 20px;
        padding: 20px;
        background: linear-gradient(145deg, #e8f1ff, #f8fbff);
    }

    .pp-header h1 {
        margin: 0;
        font-size: 36px;
        font-weight: 800;
        color: #1d4274;
    }

    .pp-header p {
        margin: 8px 0 0;
        color: var(--pp-sub);
        font-size: 15px;
        line-height: 1.65;
    }

    .pp-updated {
        display: inline-block;
        margin-top: 10px;
        font-size: 12px;
        color: #7d6a3c;
        border: 1px solid #f0d79b;
        background: #fff9ea;
        border-radius: 999px;
        padding: 5px 10px;
        font-weight: 700;
    }

    .pp-layout {
        display: grid;
        grid-template-columns: 260px 1fr;
        gap: 12px;
        margin-top: 12px;
    }

    .pp-sidebar {
        position: sticky;
        top: 14px;
        align-self: start;
        border: 1px solid var(--pp-border);
        border-radius: 14px;
        background: #fff;
        padding: 12px;
    }

    .pp-sidebar h3 {
        margin: 0 0 8px;
        font-size: 15px;
        color: #214879;
    }

    .pp-sidebar a {
        display: block;
        text-decoration: none;
        color: #45658b;
        font-size: 13px;
        border-radius: 9px;
        padding: 7px 8px;
    }

    .pp-sidebar a:hover {
        background: #f4f8ff;
        color: #224b7f;
    }

    .pp-content {
        border: 1px solid var(--pp-border);
        border-radius: 16px;
        background: #fff;
        padding: 14px;
    }

    .pp-sec {
        padding: 10px 4px 14px;
        border-bottom: 1px solid #e5eefc;
    }

    .pp-sec:last-child { border-bottom: 0; }

    .pp-sec h2 {
        margin: 0;
        font-size: 21px;
        color: #1e4376;
        font-weight: 800;
    }

    .pp-sec p {
        margin: 8px 0 0;
        font-size: 14px;
        color: #46678d;
        line-height: 1.7;
    }

    .pp-sec ul {
        margin: 8px 0 0;
        padding-left: 18px;
        color: #46678d;
    }

    .pp-sec li {
        margin: 4px 0;
        font-size: 14px;
        line-height: 1.6;
    }

    .pp-highlight {
        color: var(--pp-gold);
        font-weight: 700;
    }

    .pp-contact {
        margin-top: 12px;
        border: 1px solid #d5e3f8;
        border-radius: 14px;
        background: linear-gradient(150deg, #eef5ff, #f9fcff);
        padding: 12px;
    }

    .pp-contact h3 {
        margin: 0 0 8px;
        color: #1f4578;
        font-size: 18px;
    }

    .pp-contact p {
        margin: 4px 0;
        color: #4b6e92;
        font-size: 14px;
    }

    .pp-footer {
        margin-top: 14px;
        border: 1px solid var(--pp-border);
        border-radius: 14px;
        padding: 10px 12px;
        background: #0f2550;
        color: #dbe6ff;
        display: flex;
        justify-content: space-between;
        gap: 8px;
        font-size: 12px;
        flex-wrap: wrap;
    }

    .pp-footer a { color: #c8d8fa; text-decoration: none; }

    .pp-top-btn {
        position: fixed;
        right: 16px;
        bottom: 16px;
        width: 38px;
        height: 38px;
        border-radius: 999px;
        border: 1px solid #bcd2f5;
        background: #fff;
        color: #1f4f89;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 10px 20px rgba(26, 71, 138, .2);
        text-decoration: none;
        opacity: 0;
        transform: translateY(8px);
        pointer-events: none;
        transition: opacity .2s ease, transform .2s ease;
        z-index: 999;
    }

    .pp-top-btn.show {
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
    }

    @@media (max-width: 980px) {
        .pp-layout { grid-template-columns: 1fr; }
        .pp-sidebar { position: static; }
    }

    @@media (max-width: 640px) {
        .pp-header h1 { font-size: 30px; }
        .pp-nav { flex-direction: column; align-items: flex-start; }
    }
</style>

<div class="pp-progress" id="ppProgress"></div>

<div class="pp-page" id="top">
<a class="pp-back-link" href="javascript:history.back()">
        <i class="bi bi-arrow-left"></i>
        <span>Go Back</span>
    </a>

    <header class="pp-header">
        <h1>Privacy Policy</h1>
        <p>At Eventify, we value your privacy and are committed to protecting your personal information. This Privacy Policy explains how we collect, use, and safeguard your data when you use our platform.</p>
        <span class="pp-updated">Last Updated: March 2026</span>
    </header>

    <div class="pp-layout">
        <aside class="pp-sidebar">
            <h3>Section Navigation</h3>
            <a href="#sec1">1. Information We Collect</a>
            <a href="#sec2">2. How We Use Your Information</a>
            <a href="#sec3">3. Data Protection &amp; Security</a>
            <a href="#sec4">4. Sharing of Information</a>
            <a href="#sec5">5. Cookies &amp; Tracking</a>
            <a href="#sec6">6. User Rights</a>
            <a href="#sec7">7. Third-Party Services</a>
            <a href="#sec8">8. Updates to Policy</a>
            <a href="#sec9">9. Contact Us</a>
        </aside>

        <main class="pp-content">
            <section class="pp-sec" id="sec1">
                <h2>1. Information We Collect</h2>
                <p>We may collect the following types of information:</p>
                <ul>
                    <li>Personal Information (Name, Email, Phone Number)</li>
                    <li>Account Details (Login credentials, role)</li>
                    <li>Booking Information (Events, tickets, payments)</li>
                    <li>Usage Data (Pages visited, interactions)</li>
                </ul>
            </section>

            <section class="pp-sec" id="sec2">
                <h2>2. How We Use Your Information</h2>
                <p>We use your information to:</p>
                <ul>
                    <li>Provide and improve our services</li>
                    <li>Process bookings and transactions</li>
                    <li>Send notifications and updates</li>
                    <li>Personalize user experience</li>
                    <li>Ensure platform security</li>
                </ul>
            </section>

            <section class="pp-sec" id="sec3">
                <h2>3. Data Protection &amp; Security</h2>
                <p>We implement appropriate security measures to protect your data from unauthorized access, alteration, or disclosure.</p>
            </section>

            <section class="pp-sec" id="sec4">
                <h2>4. Sharing of Information</h2>
                <p>We do not sell your personal data. Your information may only be shared with:</p>
                <ul>
                    <li>Event organizers (for bookings)</li>
                    <li>Payment providers (for transactions)</li>
                    <li>Legal authorities (if required)</li>
                </ul>
            </section>

            <section class="pp-sec" id="sec5">
                <h2>5. Cookies &amp; Tracking</h2>
                <p>Eventify uses cookies to enhance user experience and analyze website traffic.</p>
            </section>

            <section class="pp-sec" id="sec6">
                <h2>6. User Rights</h2>
                <p>You have the right to:</p>
                <ul>
                    <li>Access your data</li>
                    <li>Update or delete your information</li>
                    <li>Opt-out of communications</li>
                </ul>
            </section>

            <section class="pp-sec" id="sec7">
                <h2>7. Third-Party Services</h2>
                <p>We may use third-party services for payments and analytics. These services have their own privacy policies.</p>
            </section>

            <section class="pp-sec" id="sec8">
                <h2>8. Updates to Policy</h2>
                <p>We may update this Privacy Policy from time to time. Changes will be reflected on this page.</p>
            </section>

            <section class="pp-sec" id="sec9">
                <h2>9. Contact Us</h2>
                <p>If you have any questions regarding this policy, contact us:</p>
                <ul>
                    <li><span class="pp-highlight">support@eventify.com</span></li>
                    <li>Ahmedabad, India</li>
                </ul>
            </section>

            <section class="pp-contact">
                <h3>Contact Info</h3>
                <p>?? support@eventify.com</p>
                <p>?? Ahmedabad, India</p>
            </section>
        </main>
    </div>
</div>

<a class="pp-top-btn" id="ppTopBtn" href="#top" aria-label="Back to top"><i class="bi bi-arrow-up"></i></a>

<script>
    (function () {
        var progress = document.getElementById('ppProgress');
        var topBtn = document.getElementById('ppTopBtn');

        function handleScroll() {
            var doc = document.documentElement;
            var total = doc.scrollHeight - doc.clientHeight;
            var scrolled = total > 0 ? (doc.scrollTop / total) * 100 : 0;
            progress.style.width = scrolled + '%';

            if (doc.scrollTop > 260) {
                topBtn.classList.add('show');
            } else {
                topBtn.classList.remove('show');
            }
        }

        document.addEventListener('scroll', handleScroll, { passive: true });
        handleScroll();
    })();
</script>



