@model Eventify.ViewModels.Auth.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Login";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Eventify - Login</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        :root { --blue-1:#253f9e; --blue-2:#2243aa; --cyan:#1db5dc; --text:#f3f7ff; --muted:#c8d8f4; --line:rgba(255,255,255,.28); }
        *{box-sizing:border-box}
        body{margin:0;min-height:100vh;font-family:"Segoe UI",Tahoma,sans-serif;background:linear-gradient(180deg,#2d47aa 0%,#2a58b1 100%);color:var(--text);display:flex;justify-content:center;align-items:flex-start;padding:18px;position:relative;overflow-x:hidden;overflow-y:auto}
        .auth-wrap{width:min(430px,100%);position:relative;z-index:1;animation:authEnter .65s ease both;margin:8px 0 18px}
        .auth-logo{display:flex;align-items:center;justify-content:center;gap:10px;margin-bottom:10px;font-size:54px;font-weight:800;letter-spacing:.3px;animation:authFadeUp .7s ease .1s both}
        .auth-logo i{font-size:28px;color:#79eaff;text-shadow:0 0 12px rgba(121,234,255,.45)}
        .card{border:1px solid var(--line);background:linear-gradient(180deg,rgba(255,255,255,.11),rgba(255,255,255,.08));border-radius:14px;padding:20px;box-shadow:0 24px 36px rgba(3,8,31,.24);backdrop-filter:blur(4px);animation:authFadeUp .75s ease .18s both;transition:transform .25s ease,box-shadow .25s ease}
        .card:hover{transform:translateY(-2px);box-shadow:0 30px 45px rgba(3,8,31,.30)}
        .card > *{animation:authFadeUp .45s ease both}
        .card > *:nth-child(1){animation-delay:.24s}.card > *:nth-child(2){animation-delay:.29s}.card > *:nth-child(3){animation-delay:.34s}.card > *:nth-child(4){animation-delay:.39s}
        h1{margin:0;font-size:40px;text-align:center;font-weight:700}.subtitle{margin:6px 0 16px;text-align:center;color:var(--muted);font-size:12px}
        .label{margin:8px 0 6px;font-size:12px;color:#deebff;font-weight:600}.field{position:relative;margin-bottom:8px}
        .field i{position:absolute;left:12px;top:50%;transform:translateY(-50%);color:#b8c9e8;font-size:13px}.field .right-icon{left:auto;right:12px;cursor:pointer}
        .field input{width:100%;height:38px;border-radius:8px;border:1px solid var(--line);background:rgba(255,255,255,.08);color:#fff;outline:none;font-size:13px;padding:0 36px;transition:border-color .2s ease,box-shadow .2s ease,background .2s ease}
        .field input:focus{border-color:rgba(150,222,255,.9);box-shadow:0 0 0 3px rgba(121,234,255,.22);background:rgba(255,255,255,.12)}
        .field input::placeholder{color:#bcd0ef}
        .role-wrap{margin:10px 0 10px}
        .role-label{margin:0 0 6px;font-size:12px;color:#deebff;font-weight:700}
        .role-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}
        .role-btn{
            border:1px solid rgba(255,255,255,.26);
            background:rgba(255,255,255,.08);
            color:#deebff;
            border-radius:9px;
            height:40px;
            font-size:12px;
            font-weight:700;
            display:flex;
            align-items:center;
            justify-content:center;
            gap:6px;
            cursor:pointer
        }
        .role-btn.active{
            border:0;
            color:#fff;
            background:linear-gradient(90deg,#376fd6,#25bedb);
            box-shadow:0 8px 14px rgba(7,20,67,.28)
        }
        .role-admin{
            margin:8px auto 0;
            width:78%;
            border-color:rgba(158,219,255,.4);
        }
        .option-row{display:flex;justify-content:space-between;align-items:center;font-size:11px;color:#e2ecff;margin:8px 0 12px}
        .option-row label{display:inline-flex;gap:6px;align-items:center;cursor:pointer}.option-row a{color:#e2ecff;text-decoration:none}
        .submit{width:100%;height:40px;border:0;border-radius:10px;color:#fff;font-size:24px;font-weight:700;cursor:pointer;background:linear-gradient(90deg,#2876f5,#14c8e8);box-shadow:0 10px 18px rgba(4,12,47,.3);transition:transform .2s ease,box-shadow .2s ease,filter .2s ease}
        .submit:hover{transform:translateY(-1px);box-shadow:0 13px 22px rgba(4,12,47,.38);filter:brightness(1.04)}
        .submit:active{transform:translateY(0)}
        .foot{margin-top:10px;text-align:center;font-size:12px;color:#d8e6ff}.foot a{color:#d8f5ff;text-decoration:none;font-weight:700}
        .msg{min-height:14px;margin-top:8px;text-align:center;font-size:11px;color:#ffd1d1}.ok{color:#d7ffe8}
        .field-error{color:#ffd1d1;font-size:10px;display:block;min-height:12px}.summary{color:#ffd1d1;font-size:11px;text-align:center;min-height:14px}
        @@keyframes authEnter{from{opacity:0;transform:translateY(14px) scale(.98)}to{opacity:1;transform:translateY(0) scale(1)}}
        @@keyframes authFadeUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
        @@media (max-width:520px){.auth-logo{font-size:42px}h1{font-size:32px}.submit{font-size:20px}.role-admin{width:100%}}
        @@media (max-height:760px){.auth-logo{font-size:46px;margin-bottom:8px}.card{padding:16px}.role-wrap{margin:8px 0 8px}}
    </style>
</head>
<body>
    <div class="auth-wrap">
        <div class="auth-logo"><i class="bi bi-plus-circle"></i>Eventify</div>
        <div class="card">
            <h1>Welcome Back</h1>
            <p class="subtitle">Sign in to your account to continue</p>

            @if (TempData["AuthMessage"] is string authMessage)
            {
                <div class="msg ok">@authMessage</div>
            }
            <div class="summary" asp-validation-summary="ModelOnly"></div>

            <form asp-action="Login" asp-controller="Auth" method="post">
                @Html.AntiForgeryToken()
                <p class="label">Email Address</p>
                <div class="field">
                    <i class="bi bi-envelope"></i>
                    <input asp-for="Email" placeholder="Enter your email" />
                </div>
                <span asp-validation-for="Email" class="field-error"></span>

                <p class="label">Password</p>
                <div class="field">
                    <i class="bi bi-lock"></i>
                    <input asp-for="Password" type="password" placeholder="Enter your password" />
                    <i id="togglePass" class="bi bi-eye right-icon"></i>
                </div>
                <span asp-validation-for="Password" class="field-error"></span>

                <div class="role-wrap">
                    <p class="role-label">I want to</p>
                    <div class="role-grid">
                        <button type="button" class="role-btn active" data-role="attend"><i class="bi bi-person"></i> Attend Events</button>
                        <button type="button" class="role-btn" data-role="organizer"><i class="bi bi-calendar"></i> Organize Events</button>
                    </div>
                    <button type="button" class="role-btn role-admin" data-role="admin"><i class="bi bi-gear"></i> Admin Panel</button>
                </div>
                <input asp-for="Role" type="hidden" id="roleInput" />

                <div class="option-row">
                    <label><input asp-for="RememberMe" /> Remember me</label>
                    <a href="/Auth/ForgotPassword">Forgot Password?</a>
                </div>

                <button class="submit" type="submit">Sign In</button>
            </form>
            <div class="foot">Don't have an account? <a href="/Auth/Register">Sign Up</a></div>
        </div>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const roleButtons = Array.from(document.querySelectorAll(".role-btn[data-role]"));
            const roleInput = document.getElementById("roleInput");
            const togglePass = document.getElementById("togglePass");
            const password = document.getElementById("Password");
            const current = (roleInput.value || "attend").toLowerCase();

            roleButtons.forEach(function (btn) { if (btn.dataset.role === current) { roleButtons.forEach(function (x) { x.classList.remove("active"); }); btn.classList.add("active"); } });
            roleButtons.forEach(function (btn) {
                btn.addEventListener("click", function () {
                    roleButtons.forEach(function (x) { x.classList.remove("active"); });
                    btn.classList.add("active");
                    roleInput.value = btn.dataset.role || "attend";
                });
            });
            togglePass.addEventListener("click", function () {
                const show = password.type === "password";
                password.type = show ? "text" : "password";
                togglePass.classList.toggle("bi-eye");
                togglePass.classList.toggle("bi-eye-slash");
            });
        });
    </script>
</body>
</html>
