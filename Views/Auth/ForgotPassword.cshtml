@model Eventify.ViewModels.Auth.ForgotPasswordViewModel
@{
    Layout = null;
    ViewData["Title"] = "Forgot Password";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Eventify - Forgot Password</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        :root{--bg1:#293f96;--bg2:#1fa5d6;--text:#f7fbff;--muted:#d4e3ff;--line:rgba(255,255,255,.18);--glass1:rgba(255,255,255,.11);--glass2:rgba(255,255,255,.06);--btn1:#3270f1;--btn2:#16c2e5;}
        *{box-sizing:border-box} body{margin:0;min-height:100vh;font-family:"Segoe UI",Tahoma,sans-serif;color:var(--text);background:radial-gradient(circle at bottom,#1da6d7 0,#2743a0 48%,#2a3e93 100%);overflow:hidden}
        .page{min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;position:relative;padding:24px}
        .orb{position:absolute;border-radius:999px;background:rgba(255,255,255,.3)} .orb.s1{width:8px;height:8px;left:7%;top:37%}.orb.s2{width:7px;height:7px;left:23%;top:58%}.orb.s3{width:6px;height:6px;right:15%;top:52%;background:#49d5f0}.orb.s4{width:8px;height:8px;right:11%;bottom:16%;background:#7fe5ff}.orb.s5{width:5px;height:5px;left:4%;bottom:27%}
        .brand{display:flex;align-items:center;gap:10px;font-size:21px;font-weight:800;margin-bottom:88px;z-index:1}.brand i{font-size:24px;color:#78e7ff}
        .card{width:min(448px,100%);padding:34px 32px;border:1px solid var(--line);border-radius:22px;background:linear-gradient(180deg,var(--glass1),var(--glass2));backdrop-filter:blur(8px);box-shadow:0 34px 60px rgba(5,14,48,.32);z-index:1}
        h1{margin:0 0 10px;text-align:center;font-size:26px;font-weight:800} .sub{margin:0 0 28px;text-align:center;color:var(--muted);font-size:14px}
        .label{display:block;margin:0 0 10px;font-size:14px;font-weight:700}
        .field{position:relative;margin-bottom:18px}.field i{position:absolute;left:16px;top:50%;transform:translateY(-50%);color:#a9bddf}.field input{width:100%;height:52px;padding:0 18px 0 48px;border-radius:16px;border:1px solid rgba(255,255,255,.16);background:rgba(255,255,255,.10);color:#fff;font-size:15px;outline:none}.field input::placeholder{color:#b9c8e2}
        .btn{width:100%;height:54px;border:0;border-radius:16px;background:linear-gradient(90deg,var(--btn1),var(--btn2));color:#fff;font-size:16px;font-weight:800;cursor:pointer;box-shadow:0 14px 28px rgba(7,17,56,.26)}
        .back{display:flex;justify-content:center;margin-top:22px}.back a{color:#68e8ff;text-decoration:none;font-size:14px}
        .summary,.field-error,.msg{font-size:12px;text-align:center}.summary,.field-error{color:#ffd7de}.msg{margin-bottom:12px;color:#dfffea}.dev{margin-bottom:12px;text-align:center;font-size:12px;color:#fff3a6}
    </style>
</head>
<body>
    <div class="page">
        <span class="orb s1"></span><span class="orb s2"></span><span class="orb s3"></span><span class="orb s4"></span><span class="orb s5"></span>
        <div class="brand"><i class="bi bi-stars"></i>Eventify</div>
        <div class="card">
            <h1>Forgot Password?</h1>
            <p class="sub">No worries, we will send you reset instructions</p>
            @if (TempData["AuthMessage"] is string authMessage) { <div class="msg">@authMessage</div> }
            @if (TempData["AuthDevCode"] is string devCode) { <div class="dev">@devCode</div> }
            <div class="summary" asp-validation-summary="ModelOnly"></div>
            <form asp-action="ForgotPassword" method="post">
                @Html.AntiForgeryToken()
                <label class="label">Email Address</label>
                <div class="field">
                    <i class="bi bi-envelope-fill"></i>
                    <input asp-for="Email" placeholder="Enter your email" />
                </div>
                <span asp-validation-for="Email" class="field-error"></span>
                <button class="btn" type="submit">Send Reset Link</button>
            </form>
            <div class="back"><a href="/Auth/Login"><i class="bi bi-arrow-left"></i> Back to Sign In</a></div>
        </div>
    </div>
</body>
</html>
