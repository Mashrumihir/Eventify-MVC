@{
    Layout = null;
    ViewData["Title"] = "Email Verified";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Eventify - Email Verified</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        :root{--bg1:#293f96;--bg2:#1fa5d6;--text:#f7fbff;--muted:#d4e3ff;--line:rgba(255,255,255,.18);--glass1:rgba(255,255,255,.11);--glass2:rgba(255,255,255,.06);--btn1:#21aef0;--btn2:#18c3e7;}
        *{box-sizing:border-box} body{margin:0;min-height:100vh;font-family:"Segoe UI",Tahoma,sans-serif;color:var(--text);background:radial-gradient(circle at bottom,#1da6d7 0,#2743a0 48%,#2a3e93 100%);overflow:hidden}
        .page{min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;position:relative;padding:24px}
        .brand{display:flex;align-items:center;gap:10px;font-size:21px;font-weight:800;margin-bottom:46px;z-index:1}.brand i{font-size:24px;color:#78e7ff}
        .card{width:min(420px,100%);padding:46px 34px;border:1px solid var(--line);border-radius:22px;background:linear-gradient(180deg,var(--glass1),var(--glass2));backdrop-filter:blur(8px);box-shadow:0 34px 60px rgba(5,14,48,.32);z-index:1;text-align:center}
        .icon{width:114px;height:114px;border-radius:999px;margin:0 auto 26px;background:linear-gradient(180deg,#21c7bf,#1fbcaa);display:flex;align-items:center;justify-content:center;font-size:56px}
        h1{margin:0 0 14px;font-size:28px;font-weight:800}.sub{margin:0 auto 34px;max-width:280px;color:var(--muted);font-size:14px;line-height:1.6}
        .btn{display:block;width:100%;height:54px;line-height:54px;border-radius:16px;background:linear-gradient(90deg,var(--btn1),var(--btn2));color:#fff;font-size:16px;font-weight:800;text-decoration:none;box-shadow:0 14px 28px rgba(7,17,56,.26)}
        .link{display:inline-block;margin-top:16px;color:#68e8ff;text-decoration:none;font-size:14px}
    </style>
</head>
<body>
    <div class="page">
        <div class="brand"><i class="bi bi-stars"></i>Eventify</div>
        <div class="card">
            <div class="icon"><i class="bi bi-check-lg"></i></div>
            <h1>Email Verified!</h1>
            <p class="sub">Your email has been successfully verified. You can now access all features of Eventify.</p>
            <a class="btn" href="/Auth/Login">Continue to Sign In</a>
            <a class="link" href="/Home/Index">Go to Homepage</a>
        </div>
    </div>
</body>
</html>
