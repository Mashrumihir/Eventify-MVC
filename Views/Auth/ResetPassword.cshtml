@model Eventify.ViewModels.Auth.ResetPasswordViewModel
@{
    Layout = null;
    ViewData["Title"] = "Reset Password";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Eventify - Reset Password</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        :root{--bg1:#293f96;--bg2:#2e8cf1;--bg3:#1ab8df;--text:#f7fbff;--muted:#d4e3ff;--line:rgba(255,255,255,.18);--glass1:rgba(255,255,255,.11);--glass2:rgba(255,255,255,.06);}
        *{box-sizing:border-box} body{margin:0;min-height:100vh;font-family:"Segoe UI",Tahoma,sans-serif;color:var(--text);background:linear-gradient(90deg,var(--bg1),var(--bg2) 60%,var(--bg3));overflow:hidden}
        .page{min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;position:relative;padding:24px}
        .orb{position:absolute;border-radius:999px;background:rgba(255,255,255,.22)} .o1{width:8px;height:8px;left:9%;top:11%}.o2{width:6px;height:6px;right:13%;top:19%}.o3{width:5px;height:5px;right:22%;top:32%}
        .brand{display:flex;align-items:center;gap:10px;font-size:21px;font-weight:800;margin-bottom:54px;z-index:1}.brand i{font-size:24px;color:#78e7ff}
        .card{width:min(420px,100%);padding:40px 40px;border:1px solid var(--line);border-radius:22px;background:linear-gradient(180deg,var(--glass1),var(--glass2));backdrop-filter:blur(8px);box-shadow:0 34px 60px rgba(5,14,48,.32);z-index:1}
        h1{margin:0 0 10px;text-align:center;font-size:26px;font-weight:800}.sub{margin:0 0 28px;text-align:center;color:var(--muted);font-size:14px}
        .field{position:relative;margin-bottom:16px}.field i{position:absolute;left:16px;top:50%;transform:translateY(-50%);color:#a9bddf}.field .toggle{left:auto;right:16px;cursor:pointer}
        .field input{width:100%;height:58px;padding:0 48px;border-radius:16px;border:1px solid rgba(255,255,255,.16);background:rgba(255,255,255,.10);color:#fff;font-size:15px;outline:none;transition:border-color .2s ease,box-shadow .2s ease,background .2s ease}.field input::placeholder{color:#b9c8e2}
        .field input:focus{border-color:rgba(135,226,255,.9);box-shadow:0 0 0 3px rgba(80,208,255,.18);background:rgba(255,255,255,.14)}
        .btn{width:100%;height:56px;border:0;border-radius:16px;background:linear-gradient(90deg,#3c7dfa,#19bfe4);color:#fff;font-size:16px;font-weight:800;cursor:pointer;box-shadow:0 14px 28px rgba(7,17,56,.26)}
        .summary,.field-error,.msg{font-size:12px;text-align:center}.summary,.field-error{color:#ffd7de}.msg{margin-bottom:12px;color:#dfffea}
        .hint{margin:-8px 0 18px;text-align:center;color:#bfe1ff;font-size:12px}
        @@media (max-width:560px){
            .page{padding:18px}
            .brand{margin-bottom:28px;font-size:18px}
            .card{padding:30px 18px;border-radius:18px}
            h1{font-size:22px}
            .sub{font-size:13px}
            .field input{height:54px}
            .btn{height:54px}
        }
    </style>
</head>
<body>
    <div class="page">
        <span class="orb o1"></span><span class="orb o2"></span><span class="orb o3"></span>
        <div class="brand"><i class="bi bi-stars"></i>Eventify</div>
        <div class="card">
            <h1>Set New Password</h1>
            <p class="sub">Create a strong password for your account</p>
            @if (TempData["AuthMessage"] is string authMessage) { <div class="msg">@authMessage</div> }
            <div class="summary" asp-validation-summary="ModelOnly"></div>
            <form asp-action="ResetPassword" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="Email" type="hidden" />
                <div class="field">
                    <i class="bi bi-lock-fill"></i>
                    <input asp-for="Password" type="password" placeholder="Create a new password" />
                    <i class="bi bi-eye toggle" data-target="Password"></i>
                </div>
                <span asp-validation-for="Password" class="field-error"></span>
                <div class="hint">Use at least 6 characters for a stronger password.</div>
                <div class="field">
                    <i class="bi bi-lock-fill"></i>
                    <input asp-for="ConfirmPassword" type="password" placeholder="Confirm your new password" />
                    <i class="bi bi-eye toggle" data-target="ConfirmPassword"></i>
                </div>
                <span asp-validation-for="ConfirmPassword" class="field-error"></span>
                <button class="btn" type="submit">Reset Password</button>
            </form>
        </div>
    </div>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            document.querySelectorAll(".toggle").forEach(function (icon) {
                icon.addEventListener("click", function () {
                    const input = document.getElementById(icon.dataset.target);
                    const show = input.type === "password";
                    input.type = show ? "text" : "password";
                    icon.classList.toggle("bi-eye");
                    icon.classList.toggle("bi-eye-slash");
                });
            });
        });
    </script>
</body>
</html>
