@model Eventify.ViewModels.AdminNewsletterSubscribersViewModel
@{
    Layout = "_AdminLayout";
}

@section PageStyles {
<style>
.ad-title{margin:0;font-size:22px;color:#1f3e76}
.ad-sub{margin:4px 0 12px;font-size:13px;color:#6b7280}
.action-msg{
    margin:0 0 12px;
    padding:10px 12px;
    border-radius:12px;
    background:#eefaf4;
    border:1px solid #c9ecd8;
    color:#0c9b5a;
    font-size:13px;
    font-weight:700;
}
.sub-create{
    margin-bottom:12px;
    padding:14px;
    border:1px solid #cfdced !important;
    border-radius:14px !important;
    background:#fff;
}
.sub-create-form{
    display:grid;
    grid-template-columns:minmax(0,1fr) auto;
    gap:12px;
    align-items:center;
}
.sub-create-input{
    width:100%;
    height:44px;
    padding:0 14px;
    border:1px solid #cfdced;
    border-radius:12px;
    font-size:13px;
    color:#21467d;
    outline:none;
}
.sub-create-btn{
    height:44px;
    padding:0 18px !important;
    border:0;
    border-radius:12px !important;
    background:linear-gradient(90deg,#315db5,#2eb2cc);
    color:#fff;
    font-size:13px !important;
    font-weight:800;
}
.sub-wrap{
    border:1px solid #cfdced !important;
    border-radius:14px !important;
    background:#fff;
    overflow:hidden;
}
.sub-top{
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:12px;
    padding:12px 14px;
    background:linear-gradient(90deg,#315db5,#2eb2cc);
    color:#fff;
}
.sub-top h2{margin:0;font-size:16px !important;color:#fff}
.sub-pill{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    min-width:44px;
    height:30px;
    padding:0 12px;
    border-radius:999px;
    background:rgba(255,255,255,.18);
    font-weight:800;
}
.sub-list{padding:12px}
.sub-item{
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:12px;
    padding:12px 14px;
    border:1px solid #d8e5f3;
    border-radius:12px;
    background:#f8fbff;
    margin-bottom:10px;
}
.sub-item:last-child{margin-bottom:0}
.sub-email{
    display:flex;
    align-items:center;
    gap:10px;
    min-width:0;
    color:#21467d;
    font-weight:700;
    font-size:13px;
}
.sub-email i{
    width:28px;
    height:28px;
    border-radius:999px;
    display:inline-flex;
    align-items:center;
    justify-content:center;
    background:#e6f0ff;
    color:#2d5cad;
    flex:0 0 auto;
}
.sub-time{
    color:#647d9d;
    font-size:12px;
    white-space:nowrap;
}
.sub-actions{
    display:flex;
    align-items:center;
    gap:10px;
}
.sub-delete-form{margin:0}
.sub-delete-btn{
    height:36px;
    padding:0 14px !important;
    border:1px solid #f1c3c3 !important;
    border-radius:10px !important;
    background:#fff5f5;
    color:#c0392b;
    font-size:12px !important;
    font-weight:700;
}
.sub-empty{
    padding:24px 16px;
    text-align:center;
    color:#647d9d;
    font-size:13px;
}
@@media(max-width:760px){
    .sub-create-form{grid-template-columns:1fr}
    .sub-top,.sub-item{flex-direction:column;align-items:flex-start}
    .sub-time{white-space:normal}
    .sub-actions{width:100%;justify-content:space-between}
}
</style>
}

<h1 class="ad-title">Newsletter Subscribers</h1>
<p class="ad-sub">View everyone who subscribed from the admin dashboard newsletter section.</p>
@if (TempData["AdminActionMessage"] is string actionMessage && !string.IsNullOrWhiteSpace(actionMessage))
{
    <p class="action-msg">@actionMessage</p>
}

<section class="card sub-create">
    <form method="post" asp-controller="Admin" asp-action="AddNewsletterSubscriber" class="sub-create-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="returnUrl" value="@Url.Action("NewsletterSubscribers", "Admin")" />
        <input class="sub-create-input" type="email" name="email" placeholder="Enter subscriber email address" required />
        <button class="sub-create-btn" type="submit">Create Subscriber</button>
    </form>
</section>

<section class="card sub-wrap">
    <div class="sub-top">
        <h2>Subscriber List</h2>
        <span class="sub-pill">@Model.TotalSubscribers</span>
    </div>

    @if (Model.Subscribers.Count == 0)
    {
        <div class="sub-empty">No newsletter subscribers yet.</div>
    }
    else
    {
        <div class="sub-list">
            @foreach (var subscriber in Model.Subscribers)
            {
                <div class="sub-item">
                    <div class="sub-email">
                        <i class="bi bi-envelope"></i>
                        <span>@subscriber.Email</span>
                    </div>
                    <div class="sub-actions">
                        <div class="sub-time">Added on @subscriber.AddedOnText</div>
                        <form method="post" asp-controller="Admin" asp-action="DeleteNewsletterSubscriber" class="sub-delete-form">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@subscriber.Id" />
                            <input type="hidden" name="returnUrl" value="@Url.Action("NewsletterSubscribers", "Admin")" />
                            <button class="sub-delete-btn" type="submit">Delete</button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }
</section>
