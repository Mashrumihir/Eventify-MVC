@model Eventify.ViewModels.AdminOrganizerApprovalViewModel
@{
    Layout = "_AdminLayout";
}

@section PageStyles {
<style>
.ad-title{margin:0;font-size:22px;color:#1f3e76}
.ad-sub{margin:4px 0 12px;font-size:13px;color:#6b7280}
.tab{margin:0 0 12px}
.tab.pill-group{background:#d8e0ee;padding:4px}
.tab .pill{font-size:11px;padding:6px 12px}
.create{
    border:1px solid #d5dfef !important;
    border-radius:14px !important;
    padding:10px !important;
    margin-bottom:10px;
}
.create-grid{
    display:grid;
    grid-template-columns:1fr 1fr 150px auto;
    gap:8px;
    align-items:end;
}
.create .f label{display:block;font-size:11px;color:#4e678b;margin-bottom:3px}
.create .f input,.create .f select{
    width:100%;
    border:1px solid #cdd9ea;
    border-radius:8px;
    height:34px;
    padding:0 10px;
    font-size:12px;
    color:#1f3e76;
}
.create .btn-grad{height:34px;padding:0 14px !important;border-radius:10px !important}
.ok-msg{margin:0 0 8px;font-size:12px !important;color:#0c9b5a;font-weight:700}

.cards{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.app{padding:14px !important;border:1px solid #d5dfef !important;border-radius:18px !important}
.app h3{margin:0;font-size:16px !important;color:#162e54}
.app .e{margin-top:2px;font-size:11px;color:#4e678b}
.line{height:1px;background:#dfe7f4;margin:10px 0 8px}
.actions{display:flex;justify-content:flex-end;align-items:center}
.action-wrap{display:flex;gap:8px}
.icon-form{margin:0}
.ic{width:36px;height:36px;border:0;border-radius:999px;color:#fff;font-size:16px;display:flex;align-items:center;justify-content:center;cursor:pointer}
.ok{background:#2563eb}
.no{background:#ff2563}
.status-edit{display:flex;align-items:center;gap:6px;margin-left:8px}
.status-edit select{
    height:30px;
    border:1px solid #cdd9ea;
    border-radius:8px;
    background:#fff;
    color:#1f3e76;
    font-size:11px;
    padding:0 8px;
    min-width:100px;
}
.status-edit .btn-mini{
    height:30px;
    border:1px solid #cdd9ea;
    border-radius:8px;
    background:#f6f9ff;
    color:#1f3e76;
    font-size:11px;
    padding:0 10px;
    cursor:pointer;
}
.status-pill{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    min-width:68px;
    height:28px;
    border-radius:999px;
    font-size:11px;
    font-weight:700;
    text-transform:lowercase;
}
.status-pill.approved{background:#ccf1df;color:#0b9960}
.status-pill.rejected{background:#ffd8e2;color:#e11d48}
.empty{padding:14px;color:#607595;font-size:12px}

@@media(max-width:980px){.cards{grid-template-columns:1fr}.create-grid{grid-template-columns:1fr}}
</style>
}

<h1 class="ad-title">Organizer Approval</h1>
<p class="ad-sub">Review and approve organizer applications.</p>

@if (TempData["AdminActionMessage"] is string actionMessage && !string.IsNullOrWhiteSpace(actionMessage))
{
    <p class="ok-msg">@actionMessage</p>
}

<section class="card create">
    <form method="post" asp-action="CreateOrganizerApplication">
        @Html.AntiForgeryToken()
        <div class="create-grid">
            <div class="f">
                <label for="organizationName">Organization Name</label>
                <input id="organizationName" name="organizationName" type="text" required />
            </div>
            <div class="f">
                <label for="email">Email</label>
                <input id="email" name="email" type="email" required />
            </div>
            <div class="f">
                <label for="status">Status</label>
                <select id="status" name="status">
                    <option value="pending">Pending</option>
                    <option value="approved">Approved</option>
                    <option value="rejected">Rejected</option>
                </select>
            </div>
            <button class="btn-grad" type="submit"><i class="bi bi-plus-lg"></i> Create</button>
        </div>
    </form>
</section>

<div class="pill-group tab">
    <a class="pill @(Model.ActiveTab=="pending"?"active":"")" href="@Url.Action("OrganizerApproval", new { status = "pending" })">Pending @Model.PendingCount</a>
    <a class="pill @(Model.ActiveTab=="approved"?"active":"")" href="@Url.Action("OrganizerApproval", new { status = "approved" })">Approved @Model.ApprovedCount</a>
    <a class="pill @(Model.ActiveTab=="rejected"?"active":"")" href="@Url.Action("OrganizerApproval", new { status = "rejected" })">Rejected @Model.RejectedCount</a>
</div>

<div class="cards">
    @if (Model.Applications.Count == 0)
    {
        <article class="card empty">No organizer applications found.</article>
    }
    @foreach (var a in Model.Applications)
    {
        <article class="card app">
            <h3>@a.OrganizationName</h3>
            <div class="e">@a.Email</div>
            <div class="line"></div>
            <div class="actions">
                @if (string.Equals(a.Status, "pending", StringComparison.OrdinalIgnoreCase))
                {
                    <div class="action-wrap">
                        <form method="post" asp-action="DecideOrganizer" class="icon-form">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@a.Id" /><input type="hidden" name="decision" value="approve" /><button class="ic ok" type="submit"><i class="bi bi-check-lg"></i></button></form>
                        <form method="post" asp-action="DecideOrganizer" class="icon-form">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@a.Id" /><input type="hidden" name="decision" value="reject" /><button class="ic no" type="submit"><i class="bi bi-x-lg"></i></button></form>
                    </div>
                }
                <form method="post" asp-action="DecideOrganizer" class="status-edit">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@a.Id" />
                    <select name="decision" aria-label="Edit status">
                        <option value="pending" selected="@(a.Status == "pending")">Pending</option>
                        <option value="approve" selected="@(a.Status == "approved")">Approved</option>
                        <option value="reject" selected="@(a.Status == "rejected")">Rejected</option>
                    </select>
                    <button class="btn-mini" type="submit">Update</button>
                </form>
            </div>
        </article>
    }
</div>
