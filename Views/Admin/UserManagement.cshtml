@model Eventify.ViewModels.AdminUserManagementViewModel
@{
    Layout = "_AdminLayout";
}

@section PageStyles {
<style>
.ad-title{margin:0;font-size:22px;color:#1f3e76}.ad-sub{margin:4px 0 12px;font-size:13px;color:#6b7280}
.msg{margin:0 0 10px;font-size:12px;color:#0b7f4d;font-weight:600}
.toolbar{
    display:grid;
    grid-template-columns:auto minmax(260px,1fr) auto;
    align-items:center;
    gap:12px;
    margin-bottom:10px;
}
.search{display:flex;justify-content:center;margin:0;min-width:0}.search input{width:min(520px,100%);padding:8px 12px;border-radius:999px;border:1px solid #b8d2f5;font-size:12px;background:#fff}
.role-filters{display:flex;gap:8px;flex-wrap:wrap;margin:0;min-width:0}
.role-filters a{
    text-decoration:none;
    padding:6px 10px;
    border-radius:999px;
    border:1px solid #b8c9e8;
    color:#2a4b80;
    background:#f2f6fd;
    font-size:11px;
    font-weight:600;
}
.role-filters a.active{
    color:#fff;
    border-color:#2e57a4;
    background:linear-gradient(90deg,#315db5,#2eb2cc);
}
.new-user-btn{
    border:0;
    border-radius:999px;
    padding:7px 12px;
    font-size:12px;
    font-weight:700;
    color:#fff;
    background:linear-gradient(90deg,#315db5,#2eb2cc);
    cursor:pointer;
}
.user-add-backdrop{
    position:fixed;
    inset:0;
    background:rgba(7,16,35,.45);
    display:none;
    align-items:center;
    justify-content:center;
    z-index:9999;
    padding:14px;
}
.user-add-modal{
    width:min(420px,100%);
    background:#fff;
    border:1px solid #cfdbee;
    border-radius:12px;
    box-shadow:0 16px 36px rgba(10,23,50,.3);
    padding:12px;
}
.user-add-modal h3{margin:0 0 10px;color:#1d3e73;font-size:15px !important}
.user-add-grid{display:grid;gap:8px}
.user-add-grid input,.user-add-grid select{
    width:100%;
    border:1px solid #c7d6ec;
    border-radius:8px;
    padding:8px 10px;
    font-size:12px;
}
.pw-wrap{position:relative}
.pw-wrap input{padding-right:62px !important}
.pw-display{position:relative;padding-right:58px}
.pw-value{display:block;overflow:hidden;text-overflow:ellipsis}
.pw-toggle{
    position:absolute;
    right:8px;
    top:50%;
    transform:translateY(-50%);
    border:1px solid #c7d6ec;
    background:#f8fbff;
    color:#214473;
    border-radius:6px;
    padding:2px 8px;
    font-size:11px;
    cursor:pointer;
}
.user-add-actions{display:flex;justify-content:flex-end;gap:8px;margin-top:10px}
.user-cancel-btn{
    border:1px solid #c5d5ea;
    background:#f7fbff;
    color:#204272;
    border-radius:8px;
    padding:5px 10px;
    font-size:12px;
    cursor:pointer;
}
.tbl{
    overflow:visible;
    border:1px solid #c7d5ea;
    border-radius:14px;
    background:#fff;
}
.thead,.tr{display:grid;grid-template-columns:170px minmax(220px,1.5fr) minmax(180px,1.1fr) .9fr .9fr .8fr minmax(220px,1.1fr);gap:0;align-items:center}
.tbl.no-bookings .thead,
.tbl.no-bookings .tr{grid-template-columns:170px minmax(240px,1.7fr) minmax(190px,1.2fr) .95fr .95fr minmax(220px,1.1fr)}
.thead{background:#355395;color:#fff;font-size:12px;font-weight:700;border-bottom:1px solid #cdd9ec}
.tr{background:#fff;border-bottom:1px solid #d6e0ef;font-size:11px}
.tr:last-child{border-bottom:0}
.thead > div,
.tr > div{
    padding:10px 12px;
    border-right:1px solid #d6e0ef;
    white-space:nowrap;
}
.thead > div{
    border-right:1px solid rgba(255,255,255,.18);
}
.thead > div:last-child,
.tr > div:last-child{
    border-right:0;
}
.status.active{color:#15803d}.status.blocked{color:#b91c1c}
.initial{width:28px;height:28px;border-radius:999px;background:#f1f5f9;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#64748b}
.usercell{display:flex;align-items:center;gap:12px}
.usercell strong{font-size:11px;line-height:1.2}
.thead > div:last-child{text-align:center}
.tr > div:last-child{text-align:center}
.actions{display:flex;gap:8px;align-items:center;justify-content:center;flex-wrap:wrap}
.action-form{margin:0}
.action-btn{
    border:1px solid #d2dceb;
    background:#f8fbff;
    color:#1e3e73;
    border-radius:6px;
    font-size:11px;
    font-weight:600;
    padding:4px 8px;
    min-width:56px;
    cursor:pointer;
    text-align:center;
    white-space:nowrap;
}
.action-btn.del{
    border-color:#fecaca;
    color:#dc2626;
    background:#fff5f5;
}
.photo-backdrop{
    position:fixed;
    inset:0;
    display:none;
    align-items:center;
    justify-content:center;
    background:rgba(7,16,35,.55);
    z-index:10000;
    padding:16px;
}
.photo-modal{
    width:min(420px,100%);
    background:#fff;
    border:1px solid #cfdbee;
    border-radius:14px;
    box-shadow:0 18px 42px rgba(10,23,50,.32);
    padding:14px;
}
.photo-modal-head{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:12px}
.photo-modal-head h3{margin:0;color:#1d3e73;font-size:16px}
.photo-close{
    border:1px solid #c7d6ec;
    background:#f8fbff;
    color:#214473;
    border-radius:8px;
    padding:4px 10px;
    font-size:12px;
    cursor:pointer;
}
.photo-preview{
    width:100%;
    aspect-ratio:1/1;
    border-radius:12px;
    overflow:hidden;
    background:#eef4ff;
    display:flex;
    align-items:center;
    justify-content:center;
    border:1px solid #d6e0ef;
}
.photo-preview img{width:100%;height:100%;object-fit:cover;display:block}
.photo-caption{margin:10px 0 0;font-size:12px;color:#4b5563}
@@media(max-width:1200px){.thead,.tr{grid-template-columns:130px minmax(170px,1.2fr) minmax(150px,1fr) .85fr .85fr .6fr minmax(190px,1fr)}.tbl.no-bookings .thead,.tbl.no-bookings .tr{grid-template-columns:130px minmax(180px,1.4fr) minmax(150px,1.05fr) .9fr .9fr minmax(190px,1fr)}.ad-title{font-size:20px}.ad-sub{font-size:12px}.toolbar{grid-template-columns:1fr}.search{justify-content:flex-start}.search input{font-size:12px}}
@@media(max-width:760px){.thead,.tr{grid-template-columns:1fr 1.15fr 1fr .85fr .85fr .7fr 150px;padding:8px 10px;font-size:10px}.tbl.no-bookings .thead,.tbl.no-bookings .tr{grid-template-columns:1fr 1.2fr 1fr .9fr .9fr 150px}.initial{width:24px;height:24px;font-size:10px}.actions{gap:6px}.action-btn{min-width:48px;padding:4px 6px}}
</style>
}

<h1 class="ad-title">User Management</h1>
<p class="ad-sub">Manage and monitor all registered users on the platform.</p>
@if (TempData["UserActionMessage"] is string actionMessage && !string.IsNullOrWhiteSpace(actionMessage))
{
    <p class="msg">@actionMessage</p>
}

@{
    var createRole = Model.ActiveRole == "all" ? "attend" : Model.ActiveRole;
}
<div class="toolbar">
    <div class="role-filters">
        <a class="@(Model.ActiveRole=="all"?"active":"")" href="@Url.Action("UserManagement", new { role = "all", q = Model.Search })">All Users</a>
        <a class="@(Model.ActiveRole=="attend"?"active":"")" href="@Url.Action("UserManagement", new { role = "attend", q = Model.Search })">Attend Users (@Model.AttendCount)</a>
        <a class="@(Model.ActiveRole=="organizer"?"active":"")" href="@Url.Action("UserManagement", new { role = "organizer", q = Model.Search })">Organizer Users (@Model.OrganizerCount)</a>
        <a class="@(Model.ActiveRole=="admin"?"active":"")" href="@Url.Action("UserManagement", new { role = "admin", q = Model.Search })">Admin Users (@Model.AdminCount)</a>
    </div>
    <form class="search" method="get">
        <input type="hidden" name="role" value="@Model.ActiveRole" />
        <input type="text" name="q" value="@Model.Search" placeholder="Search users by name or email..." />
    </form>
    <button id="openAddUserModal" class="new-user-btn" type="button"><i class="bi bi-plus-lg"></i> New User</button>
</div>

@{
    var showBookings = !string.Equals(Model.ActiveRole, "admin", StringComparison.OrdinalIgnoreCase);
}

<section class="card tbl @(showBookings ? "" : "no-bookings")">
    <div class="thead">
        <div>User</div>
        <div>Email</div>
        <div>Password</div>
        <div>Status</div>
        <div>Join Date</div>
        @if (showBookings)
        {
            <div>Bookings</div>
        }
        <div>Actions</div>
    </div>
    @foreach (var u in Model.Users)
    {
        var returnUrl = Url.Action("UserManagement", new { role = Model.ActiveRole, q = Model.Search });
        var blockLabel = string.Equals(u.Status, "blocked", StringComparison.OrdinalIgnoreCase) ? "Unblock" : "Block";
        <div class="tr">
            <div class="usercell"><span class="initial">@u.Initials</span> <strong>@u.FullName</strong></div>
            <div>@u.Email</div>
            <div class="pw-display">
                <span class="pw-value" data-password-value>@(string.IsNullOrWhiteSpace(u.PasswordText) ? "Not available" : "********")</span>
                @if (!string.IsNullOrWhiteSpace(u.PasswordText))
                {
                    <button class="pw-toggle" type="button" data-password-text="@u.PasswordText">Show</button>
                }
            </div>
            <div class="status @u.Status">@u.Status</div>
            <div>@u.JoinDate.ToString("yyyy-MM-dd")</div>
            @if (showBookings)
            {
                <div><strong>@u.Bookings</strong></div>
            }
            <div class="actions">
                @if (u.CanViewPhoto)
                {
                    <button
                        class="action-btn js-view-photo"
                        type="button"
                        data-photo-src="@u.ProfilePhotoPath"
                        data-photo-name="@u.FullName">
                        View
                    </button>
                }
                <form method="post" asp-controller="Admin" asp-action="BlockUser" class="action-form" onsubmit="return confirm('Are you sure you want to block or unblock this user?');">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@u.Id" />
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                    <button class="action-btn" type="submit">@blockLabel</button>
                </form>
                <form method="post" asp-controller="Admin" asp-action="DeleteUser" class="action-form" onsubmit="return confirm('Delete this user?');">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@u.Id" />
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                    <button class="action-btn del" type="submit">Delete</button>
                </form>
            </div>
        </div>
    }
</section>

<div id="photoPreviewBackdrop" class="photo-backdrop">
    <div class="photo-modal">
        <div class="photo-modal-head">
            <h3 id="photoPreviewTitle">Profile Photo</h3>
            <button id="closePhotoPreview" class="photo-close" type="button">Close</button>
        </div>
        <div class="photo-preview">
            <img id="photoPreviewImage" src="" alt="Profile photo preview" />
        </div>
        <p id="photoPreviewCaption" class="photo-caption"></p>
    </div>
</div>

<div id="userAddBackdrop" class="user-add-backdrop">
    <div class="user-add-modal">
        <h3>Add User</h3>
        <form method="post" asp-controller="Admin" asp-action="CreateUser">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@Url.Action("UserManagement", new { role = Model.ActiveRole, q = Model.Search })" />
            <div class="user-add-grid">
                <input type="text" name="fullName" placeholder="Full name" required />
                <input type="email" name="email" placeholder="Email" required />
                <div class="pw-wrap">
                    <input id="newUserPassword" type="password" name="password" placeholder="Password" required />
                    <button id="toggleNewUserPassword" class="pw-toggle" type="button">Show</button>
                </div>
                <select name="role" required>
                    <option value="attend" selected="@(createRole=="attend")">Attend</option>
                    <option value="organizer" selected="@(createRole=="organizer")">Organizer</option>
                    <option value="admin" selected="@(createRole=="admin")">Admin</option>
                </select>
            </div>
            <div class="user-add-actions">
                <button id="cancelAddUserModal" class="user-cancel-btn" type="button">Cancel</button>
                <button class="new-user-btn" type="submit">Add User</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    (function () {
        const openBtn = document.getElementById("openAddUserModal");
        const backdrop = document.getElementById("userAddBackdrop");
        const cancelBtn = document.getElementById("cancelAddUserModal");
        const pwInput = document.getElementById("newUserPassword");
        const pwToggle = document.getElementById("toggleNewUserPassword");
        const photoBackdrop = document.getElementById("photoPreviewBackdrop");
        const photoCloseBtn = document.getElementById("closePhotoPreview");
        const photoImage = document.getElementById("photoPreviewImage");
        const photoTitle = document.getElementById("photoPreviewTitle");
        const photoCaption = document.getElementById("photoPreviewCaption");
        if (!openBtn || !backdrop || !cancelBtn) return;

        openBtn.addEventListener("click", function () {
            backdrop.style.display = "flex";
        });

        function closeModal() {
            backdrop.style.display = "none";
        }

        cancelBtn.addEventListener("click", closeModal);
        backdrop.addEventListener("click", function (e) {
            if (e.target === backdrop) closeModal();
        });

        if (pwInput && pwToggle) {
            pwToggle.addEventListener("click", function () {
                const show = pwInput.type === "password";
                pwInput.type = show ? "text" : "password";
                pwToggle.textContent = show ? "Hide" : "Show";
            });
        }

        document.querySelectorAll(".pw-display .pw-toggle[data-password-text]").forEach(function (toggleBtn) {
            toggleBtn.addEventListener("click", function () {
                const container = toggleBtn.closest(".pw-display");
                const valueEl = container ? container.querySelector("[data-password-value]") : null;
                const password = toggleBtn.getAttribute("data-password-text") || "";
                if (!valueEl || !password) return;

                const isHidden = valueEl.textContent !== password;
                valueEl.textContent = isHidden ? password : "********";
                toggleBtn.textContent = isHidden ? "Hide" : "Show";
            });
        });

        function closePhotoModal() {
            if (!photoBackdrop || !photoImage) return;
            photoBackdrop.style.display = "none";
            photoImage.setAttribute("src", "");
        }

        if (photoBackdrop && photoCloseBtn && photoImage && photoTitle && photoCaption) {
            photoCloseBtn.addEventListener("click", closePhotoModal);
            photoBackdrop.addEventListener("click", function (e) {
                if (e.target === photoBackdrop) closePhotoModal();
            });

            document.querySelectorAll(".js-view-photo[data-photo-src]").forEach(function (btn) {
                btn.addEventListener("click", function () {
                    const src = btn.getAttribute("data-photo-src") || "";
                    const fullName = btn.getAttribute("data-photo-name") || "User";
                    if (!src) return;

                    photoImage.setAttribute("src", src);
                    photoImage.setAttribute("alt", fullName + " profile photo");
                    photoTitle.textContent = "Profile Photo";
                    photoCaption.textContent = fullName;
                    photoBackdrop.style.display = "flex";
                });
            });
        }
    })();
</script>
}
