@model Eventify.ViewModels.OrganizerManageEventsViewModel
@{
    Layout = "_OrganizerLayout";
    ViewData["Title"] = "Manage Events";
}

@section PageStyles {
<style>
.mg-wrap{padding:24px}.mg-head h1{margin:0;font-size: 27px;font-weight:800}.mg-head p{margin:8px 0 18px;color:#667085;font-size: 15px}
.mg-search{background:#fff;border:1px solid #cfd4dc;border-radius:14px;padding:12px 16px;display:flex;gap:10px;align-items:center;margin-bottom:16px}
.mg-search input{border:0;outline:0;width:100%;font-size: 14px;background:transparent}
.mg-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px}
.card{background:#fff;border-radius:22px;overflow:hidden;border:1px solid #d7dbe2;box-shadow:0 8px 20px rgba(17,24,39,.08)}
.card-head{padding:16px 20px;background:linear-gradient(90deg,#2956d9,#18b8cc);color:#fff;display:flex;justify-content:space-between;align-items:flex-start}
.card-head h3{margin:0;font-size: 22px}.card-head .d{margin-top:8px;font-size: 16px;opacity:.95}
.card-body{padding:16px 20px}
.meta{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:10px}.meta .l{color:#6b7280;font-size: 13px}.meta .v{font-size: 19px;font-weight:700;color:#101828}
.rev{font-size: 22px;font-weight:800;color:#16a34a}
.progress{height:10px;background:#e2e8f0;border-radius:999px;overflow:hidden}.progress span{display:block;height:100%;background:#2956d9}
.actions{display:flex;gap:10px;align-items:center;margin-top:14px}.btn{padding:8px 18px;border:1px solid #cdd4df;border-radius:10px;color:#344054;text-decoration:none;font-size: 14px;background:#fff}
.trash{color:#ef4444;font-size: 14px}
@@media (max-width:1200px){.mg-grid{grid-template-columns:1fr}.mg-head h1{font-size: 19px}.card-head h3{font-size: 16px}.meta .v{font-size: 14px}}
</style>
}

<section class="mg-wrap">
    <header class="mg-head">
        <h1>Manage Events</h1>
        <p>View and manage all your events.</p>
    </header>

    <form method="get" class="mg-search">
        <i class="bi bi-search" style="font-size: 12px;color:#98a2b3;"></i>
        <input type="text" name="q" value="@Model.Search" placeholder="Search events by title, location, or category..." />
    </form>

    <div class="mg-grid">
        @foreach (var item in Model.Events)
        {
            var percent = item.Capacity <= 0 ? 0 : Math.Min(100, (int)Math.Round((item.Sold * 100.0) / item.Capacity));
            <article class="card">
                <header class="card-head">
                    <div>
                        <h3>@item.Title</h3>
                        <div class="d"><i class="bi bi-calendar3"></i> @item.Date.ToString("MMMM d, yyyy")</div>
                    </div>
                    <div style="font-size: 13px;">@item.Status</div>
                </header>
                <div class="card-body">
                    <div class="meta">
                        <div>
                            <div class="l">Location</div>
                            <div class="v">@item.Location</div>
                        </div>
                        <div>
                            <div class="l">Category</div>
                            <div class="v" style="color:#3b82f6">@item.Category</div>
                        </div>
                        <div>
                            <div class="l">Revenue</div>
                            <div class="rev">&#8377;@item.Revenue.ToString("0,0")</div>
                        </div>
                        <div>
                            <div class="l">Tickets Sold</div>
                            <div class="v">@item.Sold / @item.Capacity</div>
                            <div class="progress"><span style="width:@percent%;"></span></div>
                        </div>
                    </div>

                    <div class="actions">
                        <button type="button"
                                class="btn"
                                onclick="window.location.href='@Url.Action("ViewEvent", "Organizer", new { id = item.Id })'">
                            <i class="bi bi-eye"></i> View
                        </button>
                        <button type="button"
                                class="btn"
                                onclick="window.location.href='@Url.Action("CreateEvent", "Organizer", new { id = item.Id })'">
                            <i class="bi bi-pencil"></i> Edit
                        </button>
                        <form method="post" asp-action="DeleteEvent" style="display:inline;" onsubmit="return confirm('Delete this event?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="submit" style="border:0;background:transparent;padding:0;margin:0;cursor:pointer;">
                                <i class="bi bi-trash trash"></i>
                            </button>
                        </form>
                    </div>
                </div>
            </article>
        }
    </div>
</section>

