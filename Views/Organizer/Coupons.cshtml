@model Eventify.ViewModels.OrganizerCouponsViewModel
@{
    Layout = "_OrganizerLayout";
    ViewData["Title"] = "Coupon Management";
}

@section PageStyles {
<style>
.cp-wrap{padding:24px}
.cp-head{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px}
.cp-head h1{margin:0;font-size:26px;font-weight:800}
.cp-head p{margin:6px 0 0;color:#667085;font-size:14px}
.btn-main{background:linear-gradient(90deg,#3b82f6,#22c5dc);color:#fff;border-radius:12px;padding:10px 18px;text-decoration:none;font-size:13px;border:0;cursor:pointer}
.btn-main:hover{color:#fff}

.grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px}
.card{background:#fff;border:1px solid #d9dee6;border-radius:16px;overflow:hidden}
.ch{padding:12px 14px;background:linear-gradient(90deg,#3b82f6,#22c5dc);display:flex;justify-content:space-between;color:#fff;font-size:32px;font-weight:800;line-height:1}
.cb{padding:14px}
.percent{font-size:26px;font-weight:800;color:#2563eb}
.muted{color:#667085;font-size:13px}
.bar{margin-top:8px;height:10px;background:#e2e8f0;border-radius:999px;overflow:hidden}
.bar span{display:block;height:100%;background:#3b82f6}
.row{margin-top:12px;display:flex;justify-content:flex-end;gap:8px}
.row button,.row a{border:1px solid #cfd4dc;background:#fff;padding:8px;border-radius:10px;font-size:13px;color:#344054;text-decoration:none}
.row .del{border-color:#fecaca;color:#ef4444}

.cp-modal{position:fixed;inset:0;background:rgba(15,23,42,.35);display:none;align-items:center;justify-content:center;z-index:1000;padding:16px}
.cp-modal.show{display:flex}
.cp-modal-card{width:min(640px,96vw);background:#fff;border-radius:16px;border:1px solid #d9dee6;padding:18px 18px 16px}
.cp-modal-title{margin:0 0 12px;font-size:38px;font-weight:800;color:#0f172a;line-height:1}
.cp-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.cp-grid input,.cp-grid select{border:1px solid #cfd4dc;border-radius:10px;padding:10px 12px;font-size:14px}
.cp-actions{margin-top:16px;display:flex;justify-content:flex-end;gap:10px}
.btn{border:1px solid #cfd4dc;background:#fff;color:#344054;border-radius:10px;padding:10px 16px;font-size:14px}
.btn.primary{border:0;background:linear-gradient(90deg,#3b82f6,#2563eb);color:#fff}

@@media(max-width:1200px){.grid{grid-template-columns:1fr 1fr}}
@@media(max-width:800px){.grid{grid-template-columns:1fr}.cp-grid{grid-template-columns:1fr}}
</style>
}

<section class="cp-wrap">
    <header class="cp-head">
        <div>
            <h1><i class="bi bi-bullseye" style="color:#2563eb"></i> Coupon Management</h1>
            <p>Create and manage discount coupons.</p>
        </div>
        <button id="openCouponModalBtn" class="btn-main" type="button"><i class="bi bi-plus-lg"></i> Create Coupon</button>
    </header>

    <div class="grid">
        @foreach (var c in Model.Coupons)
        {
            var percent = c.UsageLimit <= 0 ? 0 : Math.Min(100, (int)Math.Round((c.UsageCount * 100.0) / c.UsageLimit));
            <article class="card">
                <header class="ch">
                    <span><i class="bi bi-tag"></i> @c.Code</span>
                    <span style="font-size:15px;font-weight:600">@(c.IsActive ? "Active" : "Expired")</span>
                </header>
                <div class="cb">
                    <div class="percent">@c.DiscountPercent.ToString("0")%</div>
                    <div class="muted">Expires: @c.ExpiryDate.ToString("MMM d, yyyy")</div>
                    <div class="muted">Usage: @c.UsageCount / @c.UsageLimit</div>
                    <div class="bar"><span style="width:@percent%"></span></div>
                    <div class="row">
                        <form method="post" asp-action="DeleteCoupon" onsubmit="return confirm('Delete this coupon?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@c.Id" />
                            <button class="del" type="submit"><i class="bi bi-trash"></i> Delete</button>
                        </form>
                    </div>
                </div>
            </article>
        }
    </div>
</section>

<div id="couponModal" class="cp-modal" aria-hidden="true">
    <div class="cp-modal-card">
        <form method="post" asp-action="CreateCoupon">
            @Html.AntiForgeryToken()
            <h2 id="couponModalTitle" class="cp-modal-title">Create Coupon</h2>

            <div class="cp-grid">
                <input asp-for="Code" id="couponCodeInput" placeholder="Coupon code" />
                <input asp-for="DiscountPercentage" id="couponDiscountInput" type="number" min="0" max="100" step="0.01" placeholder="Discount %" />
                <input asp-for="ExpiryDate" id="couponExpiryInput" type="date" />
                <input asp-for="UsageLimit" id="couponUsageLimitInput" type="number" min="1" placeholder="Usage limit" />
                <input asp-for="UsageCount" id="couponUsageCountInput" type="number" min="0" placeholder="Usage count" />
                <select asp-for="IsActive" id="couponStatusInput">
                    <option value="true">Active</option>
                    <option value="false">Expired</option>
                </select>
            </div>

            <div class="cp-actions">
                <button id="cancelCouponModalBtn" class="btn" type="button">Cancel</button>
                <button id="couponSaveBtn" class="btn primary" type="submit">Save</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
(() => {
    const modal = document.getElementById('couponModal');
    const openBtn = document.getElementById('openCouponModalBtn');
    const cancelBtn = document.getElementById('cancelCouponModalBtn');

    const codeInput = document.getElementById('couponCodeInput');
    const discountInput = document.getElementById('couponDiscountInput');
    const expiryInput = document.getElementById('couponExpiryInput');
    const usageLimitInput = document.getElementById('couponUsageLimitInput');
    const usageCountInput = document.getElementById('couponUsageCountInput');
    const statusInput = document.getElementById('couponStatusInput');
    const title = document.getElementById('couponModalTitle');

    if (!modal || !openBtn || !cancelBtn || !codeInput || !discountInput || !expiryInput || !usageLimitInput || !usageCountInput || !statusInput || !title) return;

    const openModal = () => {
        modal.classList.add('show');
        modal.setAttribute('aria-hidden', 'false');
    };

    const closeModal = () => {
        modal.classList.remove('show');
        modal.setAttribute('aria-hidden', 'true');
    };

    const setCreateMode = () => {
        title.textContent = 'Create Coupon';
        codeInput.value = '';
        discountInput.value = '0';
        expiryInput.value = '';
        usageLimitInput.value = '100';
        usageCountInput.value = '0';
        statusInput.value = 'true';
    };

    openBtn.addEventListener('click', () => {
        setCreateMode();
        openModal();
        codeInput.focus();
    });

    cancelBtn.addEventListener('click', closeModal);
    modal.addEventListener('click', (e) => {
        if (e.target === modal) closeModal();
    });
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && modal.classList.contains('show')) closeModal();
    });
})();
</script>
}
